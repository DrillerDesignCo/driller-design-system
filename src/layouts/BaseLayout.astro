---
import { brand } from '../config/brand';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  publishDate?: string;
  modifiedDate?: string;
}

const {
  title = brand.name,
  description = brand.description,
  ogImage = '/og-default.jpg',
  canonical,
  noindex = false,
  type = 'website',
  publishDate,
  modifiedDate,
} = Astro.props;

const pageTitle = title === brand.name ? title : `${title} · ${brand.name}`;
const canonicalUrl = canonical || new URL(Astro.url.pathname, brand.url).href;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, brand.url).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <slot name="head" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={brand.name} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Article meta (blog posts) -->
    {publishDate && <meta property="article:published_time" content={publishDate} />}
    {modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}

    <!-- Geo targeting -->
    <meta name="geo.region" content="US-TX" />
    <meta name="geo.placename" content="College Station" />

    <!-- Self-hosted Poppins -->
    <link rel="preload" href="/fonts/Poppins-Regular.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/Poppins-Bold.ttf" as="font" type="font/ttf" crossorigin />

    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />

    <!-- Favicon -->
    <link rel="icon" href="/site-icon2.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" href="/logo_white-watermark.webp" media="(prefers-color-scheme: dark)" />
  </head>
  <body class="bg-surface text-on-surface font-sans antialiased">
    <!-- Floating Navigation (Solid White) -->
    <header id="site-header" class="fixed top-0 w-full z-50 bg-white shadow-sm border-b border-line transition-transform duration-300">
      <div class="max-w-7xl mx-auto flex items-center justify-between px-6 py-5 md:px-12">
        <div>
          <a href="/" class="block w-48 md:w-56" aria-label={`${brand.name} home`}>
            <img src="/logo.webp" alt={`${brand.name} Logo`} class="w-full h-auto" />
          </a>
        </div>
        
        <nav class="hidden md:flex items-center gap-8">
          {brand.nav.map((item) => {
            const isActive = Astro.url.pathname.startsWith(item.href) && (item.href as string) !== '/' || Astro.url.pathname === item.href;
            
            if ('children' in item && item.children) {
              return (
                <div class="relative group">
                  <a href={item.href} class={`text-sm font-semibold tracking-tight pb-1 border-b-2 flex items-center gap-1 transition-colors ${isActive ? 'text-primary border-on-surface' : 'text-on-surface hover:text-primary border-transparent'}`}>
                    {item.label}
                    <span class="material-symbols-outlined text-[18px]">expand_more</span>
                  </a>
                  <div class="absolute top-full left-0 pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                    <div class="bg-white rounded-xl shadow-lg border border-line p-3 min-w-[240px] flex flex-col gap-1">
                      {item.children.map((child) => (
                        <a href={child.href} class="text-sm font-medium text-on-surface hover:text-primary hover:bg-surface px-4 py-2 rounded-lg transition-colors">
                          {child.label}
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              );
            }

            return (
              <a 
                href={item.href} 
                class={`text-sm font-semibold tracking-tight pb-1 border-b-2 transition-colors ${isActive ? 'text-primary border-on-surface' : 'text-on-surface hover:text-primary border-transparent'}`}
              >
                {item.label}
              </a>
            );
          })}
        </nav>

        <div class="flex items-center gap-4">
          <a href={brand.cta.primary.href} class="bg-primary text-white px-6 py-2.5 rounded-xl font-semibold text-sm shadow-[0_10px_15px_-3px_rgba(0,116,184,0.1)] hover:scale-105 hover:shadow-lg active:scale-95 transition-all duration-200">
            {brand.cta.primary.label}
          </a>
          <!-- Mobile menu button -->
          <button id="mobile-toggle" class="md:hidden flex items-center justify-center text-on-surface" aria-label="Toggle menu" aria-expanded="false">
            <span class="material-symbols-outlined">menu</span>
          </button>
        </div>
      </div>
      
      <!-- Mobile nav -->
      <div id="mobile-nav" class="hidden px-6 pb-6 pt-6 border-t border-line" aria-hidden="true">
        <ul class="flex flex-col gap-4">
          {brand.nav.map((item) => {
            const isActive = Astro.url.pathname.startsWith(item.href) && (item.href as string) !== '/' || Astro.url.pathname === item.href;
            
            if ('children' in item && item.children) {
              return (
                <li class="flex flex-col gap-3">
                  <a href={item.href} class={`font-semibold block ${isActive ? 'text-primary' : 'text-on-surface'}`}>{item.label}</a>
                  <ul class="flex flex-col gap-3 pl-4 border-l-2 border-line ml-2">
                    {item.children.map((child) => (
                      <li>
                        <a href={child.href} class="text-sm font-medium text-on-surface/80 hover:text-primary block">{child.label}</a>
                      </li>
                    ))}
                  </ul>
                </li>
              );
            }

            return (
              <li>
                <a href={item.href} class={`font-semibold block ${isActive ? 'text-primary' : 'text-on-surface'}`}>{item.label}</a>
              </li>
            );
          })}
        </ul>
      </div>
    </header>

    <!-- Main Content -->
    <main class="pt-[90px]">
      <slot />
    </main>

    <!-- Floating Card Footer -->
    <footer class="max-w-7xl mx-auto px-6 md:px-12 pb-12 mt-20">
      <div class="bg-gradient-to-br from-primary via-primary to-dark rounded-[2.5rem] p-10 md:p-16 relative overflow-hidden isolate shadow-2xl">
        
        <!-- Watermark -->
        <div class="absolute -bottom-10 -right-10 opacity-[0.05] pointer-events-none z-0">
          <img src="/logo_white-watermark.webp" alt="Waste Falcon watermark" class="w-96 md:w-[500px] h-auto object-contain transform -rotate-12" />
        </div>

        <div class="relative z-10">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8 text-white text-sm">
            
            <!-- Brand Column -->
            <div class="lg:col-span-5 flex flex-col gap-6">
              <a href="/" aria-label={`${brand.name} home`} class="block w-48 md:w-56">
                <img src="/horizontalwastefalconlogotransparentwhite-1920w.webp" alt={`${brand.name} Logo`} class="w-full h-auto" />
              </a>
              <p class="text-white/80 leading-relaxed max-w-xs md:max-w-sm">
                Convenient. Fast. Affordable. Professional.<br />
                <br />
                Providing reliable, professional dumpster rentals and demolition services.
              </p>
              <div class="flex gap-4 mt-2">
                <a href="#" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors" aria-label="Social Link Placeholder">
                  <span class="material-symbols-outlined text-[20px]">language</span>
                </a>
                <a href="#" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors" aria-label="Social Link Placeholder">
                  <span class="material-symbols-outlined text-[20px]">language</span>
                </a>
                <a href="#" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors" aria-label="Social Link Placeholder">
                  <span class="material-symbols-outlined text-[20px]">language</span>
                </a>
              </div>
            </div>

            <!-- Services Column -->
            <div class="lg:col-span-2 flex flex-col gap-4">
              <h4 class="font-bold text-lg tracking-tight mb-2">Services</h4>
              {brand.footer.services.map((item) => (
                <a href={item.href} class="text-white/70 hover:text-white transition-colors">{item.label}</a>
              ))}
            </div>

            <!-- Company Column -->
            <div class="lg:col-span-2 flex flex-col gap-4">
              <h4 class="font-bold text-lg tracking-tight mb-2">Company</h4>
              {brand.footer.company.map((item) => (
                <a href={item.href} class="text-white/70 hover:text-white transition-colors">{item.label}</a>
              ))}
            </div>

            <!-- Service Areas Column -->
            <div class="lg:col-span-3 flex flex-col gap-4">
              <h4 class="font-bold text-lg tracking-tight mb-2">Areas We Serve</h4>
              {brand.footer.serviceAreas.map((item) => (
                <a href={item.href} class="text-white/70 hover:text-white transition-colors">{item.label}</a>
              ))}
              <a href="/service-areas/" class="text-white font-bold inline-flex items-center gap-1 group mt-2">
                <span>See all areas</span>
                <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
              </a>
            </div>

          </div>

          <!-- Legal & Copyright -->
          <div class="mt-16 pt-8 border-t border-white/20 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-white/60">
            <div class="text-center md:text-left">
              &copy; {new Date().getFullYear()} {brand.name}
            </div>
            <div class="flex flex-wrap justify-center gap-6">
              <a href="/privacy/" class="hover:text-white transition-colors">Privacy Policy</a>
              <a href="/terms/" class="hover:text-white transition-colors">Terms of Service</a>
              <a href="/accessibility/" class="hover:text-white transition-colors">Accessibility</a>
            </div>
          </div>
        </div>
      </div>
    </footer>

    <!-- Mobile menu script -->
    <script>
      const toggle = document.getElementById('mobile-toggle');
      const mobileNav = document.getElementById('mobile-nav');
      if (toggle && mobileNav) {
        toggle.addEventListener('click', () => {
          const isHidden = mobileNav.classList.contains('hidden');
          
          if (isHidden) {
            mobileNav.classList.remove('hidden');
            mobileNav.classList.add('block');
            toggle.setAttribute('aria-expanded', 'true');
            mobileNav.setAttribute('aria-hidden', 'false');
          } else {
            mobileNav.classList.add('hidden');
            mobileNav.classList.remove('block');
            toggle.setAttribute('aria-expanded', 'false');
            mobileNav.setAttribute('aria-hidden', 'true');
          }

          const icon = toggle.querySelector('.material-symbols-outlined');
          if (icon) icon.textContent = isHidden ? 'close' : 'menu';
        });
      }
    </script>

    <!-- Hide navbar on scroll down, show on scroll up -->
    <script>
      (() => {
        const header = document.getElementById('site-header');
        if (!header) return;
        let lastY = window.scrollY;
        const threshold = 10;
        window.addEventListener('scroll', () => {
          const currentY = window.scrollY;
          if (Math.abs(currentY - lastY) < threshold) return;
          if (currentY > lastY && currentY > 80) {
            header.style.transform = 'translateY(-100%)';
          } else {
            header.style.transform = 'translateY(0)';
          }
          lastY = currentY;
        }, { passive: true });
      })();
    </script>
  </body>
</html>
