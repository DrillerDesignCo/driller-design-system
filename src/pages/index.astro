---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { brand } from '../config/brand';

// Homepage FAQ items
const faqItems = [
  {
    question: "What size dumpster do I need?",
    answer: "It depends on the project. A 10-yard dumpster works for a single-room cleanout or small bathroom remodel. A 20-yard handles most whole-house cleanouts and mid-size renovations. A 30-yard is best for large construction projects, full tear-outs, or commercial jobs. Call us and describe your project — we'll recommend the right size.",
  },
  {
    question: "How long can I keep the dumpster?",
    answer: "Standard rental periods are included in your flat-rate quote. If you need more time, just call us. We're flexible and won't hit you with surprise charges.",
  },
  {
    question: "What can I put in the dumpster?",
    answer: "Most construction debris, household junk, furniture, appliances, roofing materials, drywall, and yard waste are fine. Hazardous materials like paint, chemicals, batteries, and tires aren't allowed. If you're not sure about a specific item, give us a call and we'll let you know.",
  },
  {
    question: "Do you offer same-day delivery?",
    answer: "In many cases, yes. Same-day delivery is often available depending on our schedule and your location. Call early in the day for the best chance at same-day service.",
  },
  {
    question: "How much does a dumpster rental cost?",
    answer: "Every quote includes delivery, pickup, disposal, and your rental period. Pricing depends on the dumpster size and the type of material you're disposing of. Call us at (877) 779-2783 for a free, no-obligation quote.",
  },
];

const localBusinessSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": brand.name,
  "description": brand.description,
  "url": brand.url,
  "telephone": brand.contact.phone,
  "email": brand.contact.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "7111 Raymond Stotzer Pkwy",
    "addressLocality": "College Station",
    "addressRegion": "TX",
    "postalCode": "77845",
    "addressCountry": "US",
  },
  "areaServed": [
    { "@type": "City", "name": "College Station" },
    { "@type": "City", "name": "Bryan" },
    { "@type": "City", "name": "Navasota" },
    { "@type": "City", "name": "Hearne" },
    { "@type": "City", "name": "Brenham" },
    { "@type": "City", "name": "Madisonville" },
    { "@type": "City", "name": "Cameron" },
    { "@type": "City", "name": "Rockdale" },
    { "@type": "City", "name": "Caldwell" },
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "reviewCount": "92",
    "bestRating": "5",
  },
  "priceRange": "$$",
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "07:00",
    "closes": "18:00",
  },
});
---

<BaseLayout
  title="Dumpster Rental in College Station & Bryan, TX"
  description="Waste Falcon provides dumpster rental and demolition services in College Station, Bryan, and the Brazos Valley. 10- to 30-yard roll-offs. Same-day delivery available. Call (877) 779-2783."
>
  <script type="application/ld+json" set:html={localBusinessSchema} slot="head" />

  <!-- Hero Section: Intentional Asymmetry -->
  <section class="relative pt-32 pb-24 md:pt-48 md:pb-40 overflow-hidden bg-surface">
    <div class="max-w-7xl mx-auto px-6 md:px-12 flex flex-col md:flex-row items-center gap-16 relative z-10">
      <div class="flex-[3] z-10" data-gsap="hero-text">
        <span class="text-xs uppercase tracking-[0.1em] font-semibold text-dark/80 mb-4 block">Serving the Brazos Valley</span>
        <h1 class="text-5xl md:text-6xl lg:text-7xl leading-[1.1] font-black text-dark tracking-[-0.02em] mb-8 text-balance">
          Dumpster Rental in <span class="text-primary">College Station & Bryan, TX</span>
        </h1>
        <p class="text-xl leading-relaxed text-on-surface-variant max-w-xl mb-10">
          Getting rid of waste in the Brazos Valley shouldn't slow your project down. With Waste Falcon, it won't. You tell us what you need, we drop a dumpster at your site, and we haul it away when you're done. That's it.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 w-full max-w-[500px] md:max-w-none">
          <a href="/contact/" class="flex items-center justify-center w-full sm:w-64 bg-gradient-to-br from-primary to-primary-container text-white px-6 py-4 rounded-xl font-bold text-lg shadow-[0_10px_25px_rgba(0,116,184,0.2)] hover:scale-[1.02] hover:shadow-[0_12px_30px_rgba(0,116,184,0.3)] transition-all">
            Get a Free Quote
          </a>
          <a href="tel:18777792783" class="flex items-center justify-center gap-2 w-full sm:w-64 bg-white text-primary px-6 py-4 rounded-xl font-bold text-lg border border-primary hover:scale-[1.02] hover:bg-primary/5 transition-all">
            <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">phone</span>
            (877) 779-2783
          </a>
        </div>
      </div>
      <div class="flex-[2] relative w-full" data-gsap="hero-image">
        <div class="aspect-[4/5] rounded-3xl overflow-hidden shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] rotate-2 hover:rotate-0 transition-transform duration-700">
          <img src="/hero-dumpster.webp" alt="Waste Falcon Roll-off dumpster delivered to construction job site" class="w-full h-full object-cover object-[39%_center]" />
        </div>
        <div class="absolute -bottom-6 -left-6 bg-primary text-white p-6 rounded-2xl shadow-[0_20px_25px_-5px_rgba(0,0,0,0.1)] max-w-[200px]">
          <div class="text-3xl font-black leading-none mb-1">+5 Years</div>
          <div class="text-xs font-bold uppercase tracking-[0.05em] opacity-90">Serving BCS</div>
        </div>
      </div>
    </div>
    <!-- Asymmetrical bg block -->
    <div class="absolute top-0 right-0 z-0 w-1/2 h-full bg-surface-container-low opacity-50 skew-x-[12deg] translate-x-24"></div>
  </section>

  <!-- Services: Bento Grid Layout -->
  <section class="py-24 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <div class="flex flex-col md:flex-row gap-6 mb-16 md:items-end justify-between">
        <div class="max-w-2xl">
          <h2 class="text-4xl md:text-5xl font-bold text-dark leading-tight mb-4">Our Services</h2>
          <p class="text-lg text-on-surface-variant">From a single garage cleanout to a multi-phase construction project, we match the right service to the job. Here's what we do:</p>
        </div>
        <a href="/services/" class="text-primary font-bold flex items-center gap-2 group">
          Explore all services
          <span class="material-symbols-outlined transition-transform group-hover:translate-x-1">arrow_forward</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-gsap="service-cards-grid">
        <!-- Commercial Card (Span 2) -->
        <a href="/services/commercial-dumpster-rental/" class="md:col-span-2 h-full bg-surface-container-highest rounded-2xl overflow-hidden flex flex-col md:flex-row hover:-translate-y-1 transition-transform shadow-ambient group">
          <div class="flex-1 p-10 flex flex-col">
            <span class="text-xs font-bold uppercase tracking-[0.1em] text-primary mb-4">Contract Service</span>
            <h3 class="text-2xl font-bold text-dark mb-4">Commercial Dumpster Rental</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed mb-8">Warehouses, restaurants, apartment complexes, and retail stores need waste pickup they don't have to think about. We set up a regular schedule, place the right container, and swap it before it overflows. One flat rate. One invoice. No surprises.</p>
            <span class="inline-flex items-center gap-1 text-primary font-bold mt-auto text-base">
              <span>Learn More</span>
              <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </span>
          </div>
          <div class="flex-1 min-h-[250px]">
            <img src="/commercial.webp" class="w-full h-full object-cover" alt="Waste Falcon Commercial Dumpster Rental near warehouse" />
          </div>
        </a>

        <!-- Target Tracker Card -> Construction Dumpster Rental -->
        <div class="col-span-1 h-full bg-primary text-white p-10 rounded-2xl flex flex-col justify-between shadow-ambient relative group overflow-hidden hover:-translate-y-1 transition-transform">
          <div class="relative z-10">
            <span class="text-xs font-bold uppercase tracking-[0.1em] text-white/70 mb-4 block">Heavy Duty</span>
            <h3 class="text-2xl font-bold mb-4">Construction Roll-Offs</h3>
            <p class="text-sm text-white/80 leading-relaxed">Roofers, GCs, and remodelers rely on us to keep job sites clean and on schedule. We deliver roll-off dumpsters sized for heavy construction debris.</p>
          </div>
          <div class="mt-6 relative z-10 flex-grow flex flex-col justify-end">
            <a href="/services/construction-dumpster-rental/" class="inline-flex items-center gap-1 text-white font-bold mt-auto text-base w-fit">
              <span>Learn More</span>
              <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </a>
          </div>
          <div class="absolute -bottom-10 -right-10 opacity-[0.05] transform group-hover:scale-110 transition-transform duration-700 pointer-events-none">
            <img src="/logo_white-watermark.webp" alt="Waste Falcon watermark" class="w-64 h-auto object-contain" />
          </div>
        </div>

        <!-- Residential Card -->
        <a href="/services/roll-off-dumpster-rental/" class="col-span-1 h-full bg-surface-container rounded-2xl p-10 flex flex-col justify-between hover:-translate-y-1 transition-transform shadow-ambient group">
          <div class="mb-8 rounded-lg overflow-hidden aspect-video shrink-0">
            <img src="/residential.webp" class="w-full h-full object-cover" alt="Waste Falcon Residential dumpster rental outside a home" />
          </div>
          <div class="flex flex-col flex-grow">
            <span class="text-xs font-bold uppercase tracking-[0.1em] text-dark/70 mb-4 block">Home Projects</span>
            <h3 class="text-2xl font-bold text-dark mb-4">Residential Dumpsters</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed mb-8">Tackling a home cleanout, bathroom renovation, or storm cleanup? Work at your own pace with our 10 to 30-yard containers.</p>
            <span class="inline-flex items-center gap-1 text-primary font-bold mt-auto text-base">
              <span>Learn More</span>
              <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </span>
          </div>
        </a>

        <!-- Demolition Card (Span 2) -->
        <a href="/services/demolition/" class="md:col-span-2 h-full bg-surface-container-lowest rounded-2xl flex flex-col md:flex-row overflow-hidden hover:-translate-y-1 transition-transform shadow-ambient mt-6 md:mt-0 group">
          <div class="flex-1 p-10 flex flex-col">
            <span class="text-xs font-bold uppercase tracking-[0.1em] text-primary mb-4">Tear Downs</span>
            <h3 class="text-2xl font-bold text-dark mb-4">Demolition Services</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed mb-6">Sometimes the whole thing has to come down. Our crew handles interior demo and full structure tear-downs &mdash; and we bring the containers to haul everything away in one coordinated job. No need to hire a demo crew and a hauler separately.</p>
            <span class="inline-flex items-center gap-1 text-primary font-bold mt-auto text-base">
              <span>Learn More</span>
              <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </span>
          </div>
          <div class="flex-1 min-h-[250px]">
             <img src="/demolition.webp" class="w-full h-full object-cover object-[30%_center]" alt="Waste Falcon Construction Rentals and Demolition Services" />
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose Waste Falcon: Feature Grid -->
  <section class="py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <div class="flex flex-col items-center text-center mb-20">
        <span class="text-xs uppercase tracking-[0.2em] font-black text-on-surface-variant mb-4">The Waste Falcon Difference</span>
        <h2 class="text-4xl md:text-5xl font-bold text-dark max-w-3xl leading-tight">Why Choose Waste Falcon</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8" data-gsap="features-grid">
        <!-- Feature 1 -->
        <div class="bg-surface-container-lowest p-8 rounded-2xl shadow-ambient hover:-translate-y-1 transition-transform border border-outline-variant/10">
          <div class="w-14 h-14 bg-surface-container rounded-xl flex items-center justify-center mb-6">
            <span class="material-symbols-outlined text-primary text-3xl">real_estate_agent</span>
          </div>
          <h3 class="text-xl font-bold text-dark mb-3">Locally Owned & Operated</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">The Brazos Valley deserves a waste company that picks up the phone. When you call us, you talk to our local team. Not a call center in another state.</p>
        </div>
        
        <!-- Feature 2 -->
        <div class="bg-surface-container-lowest p-8 rounded-2xl shadow-ambient hover:-translate-y-1 transition-transform border border-outline-variant/10">
          <div class="w-14 h-14 bg-surface-container rounded-xl flex items-center justify-center mb-6">
            <span class="material-symbols-outlined text-primary text-3xl">bolt</span>
          </div>
          <h3 class="text-xl font-bold text-dark mb-3">Fast, Dependable Delivery</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">We get dumpsters to your site quickly — often the same day you call. Your project keeps moving. Your job site stays clean.</p>
        </div>
        
        <!-- Feature 3 -->
        <div class="bg-surface-container-lowest p-8 rounded-2xl shadow-ambient hover:-translate-y-1 transition-transform border border-outline-variant/10">
          <div class="w-14 h-14 bg-surface-container rounded-xl flex items-center justify-center mb-6">
            <span class="material-symbols-outlined text-primary text-3xl">payments</span>
          </div>
          <h3 class="text-xl font-bold text-dark mb-3">Flat-Rate Pricing</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Every quote includes delivery, pickup, disposal, and your rental period. The number we give you is the number you pay. No hidden fees.</p>
        </div>
        
        <!-- Feature 4 -->
        <div class="bg-surface-container-lowest p-8 rounded-2xl shadow-ambient hover:-translate-y-1 transition-transform border border-outline-variant/10">
          <div class="w-14 h-14 bg-surface-container rounded-xl flex items-center justify-center mb-6">
            <span class="material-symbols-outlined text-primary text-3xl">handshake</span>
          </div>
          <h3 class="text-xl font-bold text-dark mb-3">One Company, Full Service</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">Dumpster rental, demolition, debris hauling — we handle it start to finish. Need a crew to load it? Our sister company <a href="https://bcsjunkremoval.com" target="_blank" class="text-primary font-bold hover:underline">BCS Junk Removal</a> sends a team to take care of it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works & Areas We Serve -->
  <section class="border-y border-outline-variant/15 md:flex-row flex-col flex overflow-hidden">
    <!-- How It Works -->
    <div class="flex-1 border-r border-outline-variant/15 bg-surface-container-lowest flex xl:justify-end">
      <div class="w-full max-w-[40rem] px-6 md:px-12 py-24 mr-auto xl:mr-0 xl:ml-auto">
        <span class="text-xs uppercase tracking-[0.2em] font-black text-on-surface-variant mb-4 block">The Process</span>
        <h2 class="text-4xl md:text-5xl font-bold text-dark mb-12">How It Works</h2>
        
        <div class="flex flex-col gap-10" data-gsap="process-list">
          <!-- Step 1 -->
          <div class="flex gap-6">
            <div class="flex flex-col items-center">
              <div class="w-12 h-12 rounded-full bg-primary text-white font-bold flex items-center justify-center text-lg z-10 shrink-0 shadow-md">1</div>
              <div class="w-0.5 h-full bg-outline-variant/30 mt-4 min-h-[50px]"></div>
            </div>
            <div class="pb-4">
              <h3 class="text-xl font-bold text-dark mb-2">Tell Us About Your Project</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed">Call us or fill out the online form. Let us know what you're getting rid of, where you need the dumpster, and when you need it. We'll recommend a size and give you a flat-rate quote right away.</p>
            </div>
          </div>
          
          <!-- Step 2 -->
          <div class="flex gap-6">
            <div class="flex flex-col items-center">
              <div class="w-12 h-12 rounded-full bg-primary text-white font-bold flex items-center justify-center text-lg z-10 shrink-0 shadow-md">2</div>
              <div class="w-0.5 h-full bg-outline-variant/30 mt-4 min-h-[50px]"></div>
            </div>
            <div class="pb-4">
              <h3 class="text-xl font-bold text-dark mb-2">We Drop It Off</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed">We deliver the dumpster to your location — driveway, job site, parking lot, wherever you need it. Most deliveries happen quickly, and same-day drop-off is often available.</p>
            </div>
          </div>
          
          <!-- Step 3 -->
          <div class="flex gap-6">
            <div class="flex flex-col items-center">
              <div class="w-12 h-12 rounded-full bg-primary text-white font-bold flex items-center justify-center text-lg z-10 shrink-0 shadow-md">3</div>
            </div>
            <div class="pb-4">
              <h3 class="text-xl font-bold text-dark mb-2">Fill It Up. We Haul It Away.</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed">Load at your own pace. When you're finished, give us a call. We pick up the container and handle all disposal so you never have to make a trip to the landfill.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Areas We Serve -->
    <div class="flex-1 bg-surface flex xl:justify-start relative overflow-hidden">
      <div class="w-full max-w-[40rem] px-6 md:px-12 py-24 ml-auto xl:ml-0 xl:mr-auto flex flex-col justify-center">
        <span class="text-xs uppercase tracking-[0.2em] font-black text-on-surface-variant mb-4 block">Service Radius</span>
        <h2 class="text-4xl md:text-5xl font-bold text-dark mb-8">Areas We Serve</h2>
      <p class="text-lg text-on-surface-variant mb-10 leading-relaxed max-w-lg">Waste Falcon delivers dumpsters and provides demolition services across the Brazos Valley.</p>
      
      <div class="flex flex-wrap gap-3 mb-10 relative z-10">
        <a href="/services/roll-off-dumpster-rental/college-station/" class="px-5 py-2.5 bg-white border border-outline-variant/30 rounded-full text-sm font-bold text-dark hover:border-primary hover:text-primary transition-all shadow-[0_2px_10px_rgba(0,0,0,0.03)] hover:shadow-md">College Station, TX</a>
        <a href="/services/roll-off-dumpster-rental/bryan/" class="px-5 py-2.5 bg-white border border-outline-variant/30 rounded-full text-sm font-bold text-dark hover:border-primary hover:text-primary transition-all shadow-[0_2px_10px_rgba(0,0,0,0.03)] hover:shadow-md">Bryan, TX</a>
        <a href="/services/roll-off-dumpster-rental/navasota/" class="px-5 py-2.5 bg-white border border-outline-variant/30 rounded-full text-sm font-bold text-dark hover:border-primary hover:text-primary transition-all shadow-[0_2px_10px_rgba(0,0,0,0.03)] hover:shadow-md">Navasota, TX</a>
        <a href="/services/roll-off-dumpster-rental/hearne/" class="px-5 py-2.5 bg-white border border-outline-variant/30 rounded-full text-sm font-bold text-dark hover:border-primary hover:text-primary transition-all shadow-[0_2px_10px_rgba(0,0,0,0.03)] hover:shadow-md">Hearne, TX</a>
        <span class="px-5 py-2.5 bg-white border border-outline-variant/30 rounded-full text-sm font-bold text-dark shadow-[0_2px_10px_rgba(0,0,0,0.03)]">Brenham, TX</span>
        <span class="px-5 py-2.5 bg-white border border-outline-variant/30 rounded-full text-sm font-bold text-dark shadow-[0_2px_10px_rgba(0,0,0,0.03)]">Madisonville, TX</span>
        <span class="px-5 py-2.5 bg-white border border-outline-variant/30 rounded-full text-sm font-bold text-dark shadow-[0_2px_10px_rgba(0,0,0,0.03)]">Cameron, TX</span>
        <span class="px-5 py-2.5 bg-white border border-outline-variant/30 rounded-full text-sm font-bold text-dark shadow-[0_2px_10px_rgba(0,0,0,0.03)]">Rockdale, TX</span>
        <span class="px-5 py-2.5 bg-white border border-outline-variant/30 rounded-full text-sm font-bold text-dark shadow-[0_2px_10px_rgba(0,0,0,0.03)]">Caldwell, TX</span>
      </div>
      
      <p class="text-sm text-on-surface-variant leading-relaxed max-w-lg relative z-10">
        We also serve Wellborn, Kurten, Snook, Millican, Wixon Valley, Anderson, and other communities in Brazos, Grimes, Robertson, Washington, Madison, Milam, and Burleson counties. <br/><br/>
        Not sure if we cover your area? Call <a href="tel:18777792783" class="font-bold text-primary hover:underline">(877) 779-2783</a> — if you're in our range, we'll get a dumpster to you.
      </p>

      <div class="mt-8 relative z-10">
        <a href="/service-areas/" class="inline-flex items-center gap-1 text-primary font-bold group">
          <span>See all service areas</span>
          <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </a>
      </div>

      <span class="material-symbols-outlined absolute -bottom-10 -right-10 text-[300px] text-surface-container-low opacity-40 pointer-events-none transform -rotate-12 z-0">map</span>
    </div>
  </section>

  <!-- CTA Form Section: Clean Architecture -->
  <section class="py-24 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <div class="bg-primary rounded-3xl flex flex-col lg:flex-row shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] relative isolate overflow-hidden" data-gsap="cta-form">
        
        <div class="p-12 md:p-20 lg:w-1/2 flex flex-col justify-center relative overflow-hidden">
          <!-- Background decoration -->
          <div class="absolute inset-0 bg-gradient-to-br from-primary/0 to-dark/80 pointer-events-none -z-10"></div>
          
          <!-- Left-Side Only Watermark -->
          <div class="absolute inset-0 opacity-10 pointer-events-none -z-20 flex items-center justify-center">
            <img src="/logo_white-watermark.webp" alt="Waste Falcon watermark" class="w-[200%] md:w-[150%] max-w-none h-auto object-cover transform -rotate-12" />
          </div>

          <h2 class="text-4xl md:text-5xl font-bold text-white mb-6 leading-[1.1] relative z-10">Ready to Rent<br/>a Dumpster?</h2>
          <p class="text-lg text-white/80 mb-10 max-w-md relative z-10">Stop putting off that project. Whether you need a 10-yard container for a bathroom remodel or a 30-yard roll-off for a full tear-out, Waste Falcon has the right dumpster at the right price.</p>
          
          <div class="flex flex-col items-start gap-4 relative z-10 w-full max-w-sm mt-2">
            <h3 class="text-white font-bold text-2xl">Questions?</h3>
            <a href="tel:18777792783" class="text-white font-bold text-lg inline-flex items-center gap-2 group hover:text-white/80 transition-colors">
              <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">phone</span>
              <h4 class="text-lg font-bold">Give us a call!</h4>
            </a>
            <span class="text-[15px] font-medium text-white/90 leading-relaxed px-1">Serving College Station, Bryan, and the entire Brazos Valley</span>
          </div>
        </div>
        
        <div class="bg-white/5 backdrop-blur-md p-12 md:p-20 lg:w-1/2 relative border-l border-white/10">
          <form class="flex flex-col gap-6 relative z-10" action="/contact/" method="POST">
            <h3 class="text-2xl font-bold text-white mb-2">Request a Fast Quote</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="flex flex-col gap-2">
                <label class="text-xs font-bold uppercase tracking-[0.1em] text-white/60">Full Name</label>
                <input type="text" placeholder="John Doe" name="name" required class="w-full bg-white/10 border-2 border-transparent focus:border-white focus:bg-white/20 rounded-xl p-4 text-white placeholder-white/30 outline-none transition-all" />
              </div>
              <div class="flex flex-col gap-2">
                <label class="text-xs font-bold uppercase tracking-[0.1em] text-white/60">Company (Optional)</label>
                <input type="text" placeholder="Waste Falcon" name="company" class="w-full bg-white/10 border-2 border-transparent focus:border-white focus:bg-white/20 rounded-xl p-4 text-white placeholder-white/30 outline-none transition-all" />
              </div>
            </div>
            <div class="flex flex-col gap-2">
              <label class="text-xs font-bold uppercase tracking-[0.1em] text-white/60">Dumpster Size Interest</label>
              <div class="relative">
                <select name="service" class="w-full bg-white/10 border-2 border-transparent focus:border-white focus:bg-white/20 rounded-xl p-4 text-white outline-none appearance-none transition-all cursor-pointer hover:bg-white/20">
                  <option class="text-primary">Not Sure - Call me to discuss</option>
                  <option class="text-primary">10 Yard Dumpster</option>
                  <option class="text-primary">15 Yard Dumpster</option>
                  <option class="text-primary">20 Yard Dumpster</option>
                  <option class="text-primary">30 Yard Dumpster</option>
                  <option class="text-primary">Commercial Dumpster Request</option>
                  <option class="text-primary">Demolition Services</option>
                </select>
                <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-white/60 pointer-events-none">expand_more</span>
              </div>
            </div>
            <div class="flex flex-col gap-2">
              <label class="text-xs font-bold uppercase tracking-[0.1em] text-white/60">Message (Optional)</label>
              <textarea placeholder="Tell us about what you're tossing out..." rows="3" name="message" class="w-full bg-white/10 border-2 border-transparent focus:border-white focus:bg-white/20 rounded-xl p-4 text-white placeholder-white/30 outline-none transition-all resize-y"></textarea>
            </div>
            <button type="submit" class="w-full p-5 bg-white text-primary font-black uppercase tracking-[0.1em] rounded-xl mt-4 shadow-[0_10px_15px_-3px_rgba(0,0,0,0.1)] hover:bg-surface-container-lowest transition-colors flex justify-center items-center gap-2">
              Secure My Quote
              <span class="material-symbols-outlined">arrow_forward</span>
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section reusing existing component -->
  <FAQAccordion items={faqItems} />

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    
    gsap.registerPlugin(ScrollTrigger);

    // Hero Animations
    gsap.from('[data-gsap="hero-text"] > *', {
      y: 30,
      opacity: 0,
      duration: 0.8,
      stagger: 0.15,
      ease: "power3.out",
      delay: 0.1
    });

    gsap.from('[data-gsap="hero-image"]', {
      scale: 1.05,
      opacity: 0,
      duration: 1.2,
      ease: "power3.out",
      delay: 0.2
    });

    // Scroll Animations
    gsap.from('[data-gsap="service-cards-grid"] > *', {
      scrollTrigger: {
        trigger: '[data-gsap="service-cards-grid"]',
        start: "top 80%",
      },
      y: 40,
      opacity: 0,
      duration: 0.6,
      stagger: 0.1,
      ease: "power2.out",
      clearProps: "all"
    });

    gsap.from('[data-gsap="features-grid"] > div', {
      scrollTrigger: {
        trigger: '[data-gsap="features-grid"]',
        start: "top 85%",
      },
      y: 30,
      opacity: 0,
      duration: 0.5,
      stagger: 0.1,
      ease: "power2.out",
      clearProps: "all"
    });

    gsap.from('[data-gsap="process-list"] > div', {
      scrollTrigger: {
        trigger: '[data-gsap="process-list"]',
        start: "top 80%",
      },
      x: -30,
      opacity: 0,
      duration: 0.6,
      stagger: 0.15,
      ease: "power2.out",
      clearProps: "all"
    });

    gsap.from('[data-gsap="cta-form"]', {
      scrollTrigger: {
        trigger: '[data-gsap="cta-form"]',
        start: "top 85%",
      },
      y: 40,
      opacity: 0,
      duration: 0.8,
      ease: "power3.out",
      clearProps: "all"
    });
  </script>
</BaseLayout>
