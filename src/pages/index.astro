---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CTABlock from '../components/CTABlock.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { brand } from '../config/brand';
---

<BaseLayout title="Starter — Ship Faster. Look Better.">

  <!-- Hero -->
  <Hero
    eyebrow="By Driller Design Co."
    headline="Ship Client Sites in Days, Not Weeks."
    description="A premium Astro starter with a three-font typography system, layered design tokens, and reusable components. One config file rebrands everything."
  />

  <!-- Social Proof Bar -->
  <section class="proof-bar">
    <div class="container">
      <div class="proof-items">
        <div class="proof-item">
          <span class="proof-number">0 kb</span>
          <span class="proof-label body-lg">JavaScript shipped by default</span>
        </div>
        <div class="proof-item">
          <span class="proof-number">100</span>
          <span class="proof-label body-lg">Lighthouse performance score</span>
        </div>
        <div class="proof-item">
          <span class="proof-number">1</span>
          <span class="proof-label body-lg">Config file to rebrand everything</span>
        </div>
        <div class="proof-item">
          <span class="proof-number">∞</span>
          <span class="proof-label body-lg">Client sites per license</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="section" id="features" style="background: var(--surface);">
    <div class="container">
      <span class="micro-label" style="color: var(--accent); display: block; margin-bottom: 0.75rem;">WHAT'S INCLUDED</span>
      <h2 style="margin-bottom: 3rem;">Everything You Need. Nothing You Don't.</h2>
      <div class="features-grid">
        <div class="card feature-card">
          <div class="feature-icon">🎨</div>
          <h3>One Config File</h3>
          <p class="body-lg">Change <code>brand.ts</code> and the entire site rebrands — colors, fonts, nav, CTAs, footer. No hunting through files.</p>
        </div>
        <div class="card feature-card">
          <div class="feature-icon">🔤</div>
          <h3>Three-Font System</h3>
          <p class="body-lg">DM Serif Display for hero headlines. Poppins for UI. Source Serif 4 for reading. Editorial hierarchy built in.</p>
        </div>
        <div class="card feature-card">
          <div class="feature-icon">🎯</div>
          <h3>Layered Design Tokens</h3>
          <p class="body-lg">Three-layer CSS variable system: primitives → semantic → component. Swap 10 values and the entire system cascades.</p>
        </div>
        <div class="card feature-card">
          <div class="feature-icon">⚡</div>
          <h3>Zero JS by Default</h3>
          <p class="body-lg">Astro ships zero JavaScript unless you opt in. Perfect Lighthouse scores out of the box.</p>
        </div>
        <div class="card feature-card">
          <div class="feature-icon">📐</div>
          <h3>Component Library</h3>
          <p class="body-lg">Hero, CTA blocks, FAQ accordion, cards — pre-built and production-ready. Compose pages in minutes.</p>
        </div>
        <div class="card feature-card">
          <div class="feature-icon">🌗</div>
          <h3>Light & Dark Modes</h3>
          <p class="body-lg">Add <code>.dark-section</code> to any element and the token context flips. Mix and match freely.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Typography Showcase -->
  <section class="section" id="typography">
    <div class="container">
      <span class="micro-label" style="color: var(--accent); display: block; margin-bottom: 0.75rem;">TYPE SYSTEM</span>
      <h2 style="margin-bottom: 3rem;">Three Fonts. Infinite Hierarchy.</h2>

      <div class="type-showcase">
        <div class="type-row">
          <span class="micro-label type-label">DM SERIF DISPLAY</span>
          <p class="display-xl type-sample">The headline that stops the scroll.</p>
        </div>
        <hr class="divider" />
        <div class="type-row">
          <span class="micro-label type-label">POPPINS</span>
          <p class="type-sample" style="font-size: 1.25rem; font-weight: 600;">The subheading that structures the story.</p>
        </div>
        <hr class="divider" />
        <div class="type-row">
          <span class="micro-label type-label">SOURCE SERIF 4</span>
          <p class="reading-text type-sample">The paragraph that invites you to keep reading. Source Serif 4 was designed for comfortable extended reading on screens — the digital equivalent of a well-set book. <em>It even has true italics.</em></p>
        </div>
        <hr class="divider" />
        <div class="type-row">
          <span class="micro-label type-label">MICRO LABEL</span>
          <p class="micro-label type-sample" style="color: var(--text);">POPPINS 600 · 0.12EM TRACKING · UPPERCASE</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Component Showcase -->
  <section class="section" style="background: var(--surface);">
    <div class="container">
      <span class="micro-label" style="color: var(--accent); display: block; margin-bottom: 0.75rem;">COMPONENTS</span>
      <h2 style="margin-bottom: 1.5rem;">Pre-Built. Production-Ready.</h2>
      <p class="body-lg" style="max-width: 560px; margin-bottom: 3rem;">Every component reads from the token system. Rebrand the tokens, and every button, card, and heading updates automatically.</p>

      <div class="component-demo">
        <div class="demo-row">
          <span class="micro-label" style="color: var(--text-faint);">BUTTONS</span>
          <div class="demo-buttons">
            <a href="#" class="btn btn-primary">Primary Action</a>
            <a href="#" class="btn btn-secondary">Secondary Action</a>
          </div>
        </div>

        <div class="demo-row">
          <span class="micro-label" style="color: var(--text-faint);">CARDS</span>
          <div class="demo-cards">
            <div class="card">
              <h3>Card Title</h3>
              <p class="body-lg">Description that explains value in a sentence or two.</p>
              <span class="micro-label" style="color: var(--accent);">Learn More →</span>
            </div>
            <div class="card">
              <h3>Another Card</h3>
              <p class="body-lg">Cards get rounded corners, hover elevation, and spacing from the token system.</p>
              <span class="micro-label" style="color: var(--accent);">Explore →</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section">
    <div class="container">
      <span class="micro-label" style="color: var(--accent); display: block; margin-bottom: 0.75rem;">HOW IT WORKS</span>
      <h2 style="margin-bottom: 3rem;">New Client Site in Three Steps</h2>
      <div class="steps-grid">
        <div class="step">
          <span class="step-number">01</span>
          <h3>Download & Install</h3>
          <p class="body-lg">Unzip the template. Run <code>npm install</code> and your dev server is live in under 60 seconds.</p>
        </div>
        <div class="step">
          <span class="step-number">02</span>
          <h3>Update brand.ts</h3>
          <p class="body-lg">Swap the company name, colors, fonts, nav links, and CTAs. That's 15 values. The entire site rebrands.</p>
        </div>
        <div class="step">
          <span class="step-number">03</span>
          <h3>Add Content & Ship</h3>
          <p class="body-lg">Drop in copy, images, and services. Deploy to Vercel, Netlify, or any static host.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section" id="pricing" style="background: var(--surface);">
    <div class="container pricing-container">
      <span class="micro-label" style="color: var(--accent); display: block; margin-bottom: 0.75rem; text-align: center;">PRICING</span>
      <h2 class="display-lg" style="text-align: center; margin-bottom: 1rem;">One Template. Unlimited Projects.</h2>
      <p class="body-lg" style="text-align: center; max-width: 500px; margin: 0 auto 3rem;">Buy once, use forever. No subscriptions, no per-site fees, no revenue share.</p>

      <div class="pricing-grid">
        <div class="pricing-card card">
          <div class="pricing-tier">
            <span class="micro-label">STARTER</span>
            <div class="pricing-price">
              <span class="price-amount">$49</span>
              <span class="price-note body-lg">one-time</span>
            </div>
          </div>
          <ul class="pricing-features">
            <li>✓ Full source code</li>
            <li>✓ All components (Hero, CTA, FAQ, Cards)</li>
            <li>✓ Three-font typography system</li>
            <li>✓ Layered design token architecture</li>
            <li>✓ Light + dark section modes</li>
            <li>✓ Responsive layouts</li>
            <li>✓ Unlimited client projects</li>
          </ul>
          <a href="#" class="btn btn-secondary" style="width: 100%;">Get Starter</a>
        </div>

        <div class="pricing-card pricing-featured card">
          <div class="pricing-badge micro-label">MOST POPULAR</div>
          <div class="pricing-tier">
            <span class="micro-label">AGENCY</span>
            <div class="pricing-price">
              <span class="price-amount">$149</span>
              <span class="price-note body-lg">one-time</span>
            </div>
          </div>
          <ul class="pricing-features">
            <li>✓ Everything in Starter</li>
            <li>✓ Blog & article layout system</li>
            <li>✓ Content Collections setup</li>
            <li>✓ SEO meta & JSON-LD schemas</li>
            <li>✓ Contact form with validation</li>
            <li>✓ Services & case study templates</li>
            <li>✓ Priority support for 6 months</li>
          </ul>
          <a href="#" class="btn btn-primary" style="width: 100%;">Get Agency</a>
        </div>

        <div class="pricing-card card">
          <div class="pricing-tier">
            <span class="micro-label">STUDIO</span>
            <div class="pricing-price">
              <span class="price-amount">$349</span>
              <span class="price-note body-lg">one-time</span>
            </div>
          </div>
          <ul class="pricing-features">
            <li>✓ Everything in Agency</li>
            <li>✓ CMS integration (Sanity / Contentful)</li>
            <li>✓ Multi-language support</li>
            <li>✓ Analytics dashboard template</li>
            <li>✓ Client portal page template</li>
            <li>✓ White-label rights</li>
            <li>✓ Lifetime priority support</li>
          </ul>
          <a href="#" class="btn btn-secondary" style="width: 100%;">Get Studio</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <FAQAccordion
        headline="Common Questions"
        items={[
          {
            question: "Can I use this for unlimited client projects?",
            answer: "Yes. All tiers include unlimited client projects. Buy once, use forever — no per-site fees or revenue share."
          },
          {
            question: "Do I get source code access?",
            answer: "Yes. You get the full, unminified Astro source code. Fork it, modify it, extend it — it's yours."
          },
          {
            question: "What if I need help customizing it?",
            answer: "Agency and Studio tiers include priority support. Or hire Driller Design Co. for custom implementation — we built it, we know it best."
          },
          {
            question: "Can I swap the fonts and colors?",
            answer: "That's the whole point. Change 15 values in brand.ts and the entire site rebrands. Colors, fonts, nav, CTAs — everything cascades automatically."
          },
          {
            question: "Is this SEO optimized?",
            answer: "Yes. Astro renders static HTML at build time. Fast load times, semantic markup, proper heading hierarchy, and meta tags are all built in. Agency tier adds JSON-LD schemas."
          },
          {
            question: "What's your refund policy?",
            answer: "Full refund within 14 days if the template doesn't work for you. No questions asked."
          },
        ]}
      />
    </div>
  </section>

  <!-- Final CTA -->
  <CTABlock
    headline="Stop Building from Scratch."
    description="Your next client site is one config file away."
  />

</BaseLayout>

<style>
  /* Proof Bar */
  .proof-bar {
    padding: 2.5rem 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .proof-items {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .proof-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .proof-number {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--text);
    line-height: 1.2;
  }

  .proof-label {
    font-size: 0.8125rem !important;
  }

  /* Features */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .feature-icon {
    font-size: 1.5rem;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-soft);
    border-radius: 10px;
  }

  .feature-card code {
    background: var(--accent-soft);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.875rem;
    color: var(--accent);
  }

  /* Typography */
  .type-showcase {
    max-width: 800px;
  }

  .type-row {
    padding: 2rem 0;
  }

  .type-label {
    color: var(--text-faint) !important;
    display: block;
    margin-bottom: 0.75rem;
  }

  .type-sample {
    color: var(--text);
  }

  /* Component demos */
  .component-demo {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .demo-row {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .demo-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .demo-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .demo-cards .card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* Steps */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }

  .step {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .step-number {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--accent-bg);
    line-height: 1;
  }

  .step code {
    background: var(--accent-soft);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.875rem;
    color: var(--accent);
  }

  /* Pricing */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .pricing-card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2.5rem;
    position: relative;
  }

  .pricing-featured {
    border-color: var(--accent-bg);
    border-width: 2px;
    box-shadow: 0 8px 32px rgba(212, 118, 78, 0.15);
  }

  .pricing-badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent-bg);
    color: var(--color-dark);
    padding: 0.25rem 1rem;
    border-radius: 100px;
    font-size: 0.625rem;
    white-space: nowrap;
  }

  .pricing-tier {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .pricing-price {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .price-amount {
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--text);
    line-height: 1;
  }

  .price-note {
    font-size: 0.875rem !important;
  }

  .pricing-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    font-size: 0.9375rem;
    color: var(--text-muted);
  }

  .pricing-features li {
    padding-left: 0.25rem;
  }

  @media (max-width: 768px) {
    .proof-items {
      grid-template-columns: repeat(2, 1fr);
    }

    .features-grid,
    .steps-grid,
    .pricing-grid {
      grid-template-columns: 1fr;
    }

    .demo-cards {
      grid-template-columns: 1fr;
    }

    .pricing-featured {
      order: -1;
    }
  }
</style>
