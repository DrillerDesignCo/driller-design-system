---
import { brand } from '../config/brand';
import Button from './md/Button.astro';

interface Props {
  eyebrow?: string;
  headline: string;
  description?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string } | undefined;
}

const {
  eyebrow = brand.location,
  headline,
  description,
  primaryCta = brand.cta.primary,
  secondaryCta = brand.cta.secondary,
} = Astro.props;
---

<section class="hero">
  <div class="container hero-inner">
    {eyebrow && <span class="micro-label hero-eyebrow">{eyebrow}</span>}
    <h1 class="display-xl hero-headline">{headline}</h1>
    {description && <p class="body-lg hero-description">{description}</p>}
    <div class="hero-actions">
      <Button variant="filled" href={primaryCta.href}>{primaryCta.label}</Button>
      {secondaryCta && (
        <Button variant="filled-tonal" href={secondaryCta.href}>
          {secondaryCta.label}
        </Button>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 7rem 0 5rem;
    display: flex;
    align-items: center;
    min-height: 65vh;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 720px;
  }

  .hero-eyebrow {
    color: var(--color-primary);
  }

  .hero-headline {
    color: var(--text);
  }

  .hero-description {
    max-width: 560px;
    color: var(--text-muted);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 5rem 0 4rem;
      min-height: auto;
    }

    .hero-inner {
      text-align: center;
      align-items: center;
    }

    .hero-actions {
      flex-direction: column;
      width: 100%;
      max-width: 400px;
    }

    /* Target the Button component inside hero-actions to stretch full width on mobile */
    .hero-actions > :global(.md-button) {
      width: 100%;
    }
  }
</style>
