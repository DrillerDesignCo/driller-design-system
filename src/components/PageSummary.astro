---
/**
 * PageSummary — A social proof / stats bar used beneath heroes.
 * Renders 2–4 stat items in a horizontal row.
 */

interface StatItem {
  value: string;
  label: string;
}

interface Props {
  items: StatItem[];
  class?: string;
}

const { items, class: className, ...attrs } = Astro.props;
---

<section class:list={['page-summary', className]} {...attrs}>
  <div class="container">
    <div class="page-summary__items">
      {items.map((item) => (
        <div class="page-summary__item">
          <span class="page-summary__value">{item.value}</span>
          <span class="page-summary__label body-lg">{item.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .page-summary {
    padding: 3rem 0;
    border-bottom: 1px solid var(--line);
  }

  .page-summary__items {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 2rem;
    text-align: center;
  }

  .page-summary__item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    align-items: center;
  }

  .page-summary__value {
    font-family: var(--md-sys-typescale-display-small-font);
    font-weight: var(--md-sys-typescale-display-small-weight);
    font-size: var(--md-sys-typescale-display-small-size);
    line-height: var(--md-sys-typescale-display-small-line-height);
    color: var(--color-primary, var(--text));
  }

  .page-summary__label {
    max-width: 180px;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .page-summary__items {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
