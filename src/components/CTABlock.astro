---
import { brand } from '../config/brand';
import Button from './md/Button.astro';

interface Props {
  headline?: string;
  description?: string;
  cta?: { label: string; href: string };
  variant?: 'light' | 'dark';
}

const {
  headline = "Ready to Scale?",
  description = "Bring the business. We'll architect the blueprint.",
  cta = brand.cta.primary,
  variant = 'dark',
} = Astro.props;
---

<section class={`cta-block section ${variant === 'dark' ? 'dark-section' : ''}`}>
  <div class="container cta-inner">
    <span class="micro-label" style="color: var(--color-primary);">LET'S WORK TOGETHER</span>
    <h2 class="display-lg cta-headline">{headline}</h2>
    {description && <p class="body-lg cta-description">{description}</p>}
    <Button variant="filled" href={cta.href}>{cta.label}</Button>
  </div>
</section>

<style>
  .cta-block {
    text-align: center;
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-description {
    max-width: 500px;
  }

  @media (max-width: 768px) {
    .cta-inner {
      padding: 0 1rem;
    }
    
    .cta-inner > :global(.md-button) {
      width: 100%;
      max-width: 320px;
    }
  }
</style>
