/**
 * Material Design 3 — SubMenu
 * A wrapper that nests a Menu inside a MenuItem, opening on hover or click.
 *
 * Usage:
 *   <SubMenu>
 *     <MenuItem slot="item" label="More options" />
 *     <Menu slot="menu">
 *       <MenuItem label="Sub-option 1" />
 *       <MenuItem label="Sub-option 2" />
 *     </Menu>
 *   </SubMenu>
 */

interface Props {
  hoverOpenDelay?: number;
  hoverCloseDelay?: number;
  class?: string;
}

const {
  hoverOpenDelay = 400,
  hoverCloseDelay = 400,
  class: className,
  ...attrs
} = Astro.props;
---

<span
  class:list={['md-sub-menu', className]}
  data-hover-open-delay={hoverOpenDelay}
  data-hover-close-delay={hoverCloseDelay}
  {...attrs}
>
  <span class="md-sub-menu__item">
    <slot name="item" />
  </span>
  <span class="md-sub-menu__menu">
    <slot name="menu" />
  </span>
</span>

<style>
  /* ─── SubMenu root (anchor for the nested menu) ─────────── */
  .md-sub-menu {
    position: relative;
    display: contents;
  }

  /* ─── Trigger item slot ─────────────────────────────────── */
  .md-sub-menu__item {
    display: contents;
  }

  /* ─── Nested menu slot — hidden by default ─────────────── */
  .md-sub-menu__menu {
    display: block;
    position: absolute;
    top: 0;
    inset-inline-start: 100%;
    z-index: 10;
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.12s ease,
      visibility 0s ease 0.12s;
  }

  /* When the nested menu is open, show the slot container */
  .md-sub-menu__menu:has(.md-menu--open) {
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
    transition:
      opacity 0.12s ease,
      visibility 0s ease 0s;
  }

  /*
   * Override the nested menu's positioning when inside a SubMenu
   * so it anchors beside the trigger item rather than using its
   * own absolute-from-anchor logic.
   */
  .md-sub-menu__menu :global(.md-menu) {
    position: relative;
    top: auto;
    left: auto;
    inset-inline-start: auto;
  }
</style>

<script>
  document.querySelectorAll('.md-sub-menu').forEach((subMenu) => {
    const itemSlot = subMenu.querySelector('.md-sub-menu__item');
    const menuSlot = subMenu.querySelector('.md-sub-menu__menu');
    const menu = menuSlot?.querySelector('.md-menu') as HTMLElement | null;
    if (!itemSlot || !menu) return;

    const openDelay = parseInt(
      (subMenu as HTMLElement).getAttribute('data-hover-open-delay') || '400',
    );
    const closeDelay = parseInt(
      (subMenu as HTMLElement).getAttribute('data-hover-close-delay') || '400',
    );
    let openTimeout = 0;
    let closeTimeout = 0;

    function showMenu() {
      clearTimeout(closeTimeout);
      menu!.classList.add('md-menu--open');
      menu!.removeAttribute('aria-hidden');
    }

    function hideMenu() {
      clearTimeout(openTimeout);
      menu!.classList.remove('md-menu--open');
      menu!.setAttribute('aria-hidden', 'true');
    }

    // ── Hover open/close with configurable delays ──────────
    subMenu.addEventListener('mouseenter', () => {
      clearTimeout(closeTimeout);
      if (menu!.classList.contains('md-menu--open')) return;
      openTimeout = setTimeout(showMenu, openDelay) as unknown as number;
    });

    subMenu.addEventListener('mouseleave', () => {
      clearTimeout(openTimeout);
      closeTimeout = setTimeout(hideMenu, closeDelay) as unknown as number;
    });

    // ── Click opens immediately ────────────────────────────
    itemSlot.addEventListener('click', (e) => {
      e.stopPropagation();
      showMenu();
    });

    // ── Keyboard: open submenu (RTL-aware) ─────────────────
    itemSlot.addEventListener('keydown', (e) => {
      const event = e as KeyboardEvent;
      const isRtl = getComputedStyle(subMenu).direction === 'rtl';
      const openKey = isRtl ? 'ArrowLeft' : 'ArrowRight';
      if (
        event.key === openKey ||
        event.key === 'Enter' ||
        event.key === ' '
      ) {
        event.preventDefault();
        event.stopPropagation();
        showMenu();
        const firstItem = menu!.querySelector(
          '.md-menu-item:not([disabled])',
        ) as HTMLElement | null;
        if (firstItem) firstItem.focus();
      }
    });

    // ── Keyboard: close submenu (RTL-aware) ────────────────
    menuSlot!.addEventListener('keydown', (e) => {
      const event = e as KeyboardEvent;
      const isRtl = getComputedStyle(subMenu).direction === 'rtl';
      const closeKey = isRtl ? 'ArrowRight' : 'ArrowLeft';
      if (event.key === closeKey || event.key === 'Escape') {
        event.preventDefault();
        event.stopPropagation();
        hideMenu();
        const trigger = itemSlot.querySelector(
          'button, [role="menuitem"]',
        ) as HTMLElement | null;
        if (trigger) trigger.focus();
      }
    });
  });
</script>
