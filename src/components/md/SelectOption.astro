/**
 * Material Design 3 — SelectOption
 * A single option item rendered inside an md-select dropdown.
 *
 * Usage:
 *   <SelectOption value="apple" headline="Apple" />
 *   <SelectOption value="banana" headline="Banana" selected />
 *   <SelectOption value="cherry" headline="Cherry" disabled />
 */

interface Props {
  value: string;
  headline: string;
  selected?: boolean;
  disabled?: boolean;
  [key: string]: any;
}

const {
  value,
  headline,
  selected = false,
  disabled = false,
  ...attrs
} = Astro.props;
---

<li
  class:list={[
    'md-select-option',
    { 'selected': selected, 'disabled': disabled },
  ]}
  role="option"
  aria-selected={selected ? 'true' : 'false'}
  aria-disabled={disabled ? 'true' : undefined}
  tabindex={disabled ? -1 : 0}
  data-value={value}
  {...attrs}
>
  <span class="md-select-option__state-layer" aria-hidden="true"></span>
  <span class="md-select-option__leading-icon" aria-hidden="true">
    {selected && (
      <svg class="md-select-option__check" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M9.55 18.2 3.65 12.3 5.275 10.675 9.55 14.95 18.725 5.775 20.35 7.4Z" />
      </svg>
    )}
  </span>
  <span class="md-select-option__headline">{headline}</span>
</li>

<style>
  /* ═══════════════════════════════════════
     SELECT OPTION — Base
     ═══════════════════════════════════════ */
  .md-select-option {
    --_container-color: var(--surface);
    --_selected-container-color: var(--accent-soft, color-mix(in srgb, var(--color-primary) 12%, transparent));
    --_label-color: var(--text);
    --_selected-label-color: var(--color-primary);
    --_disabled-label-color: var(--text-muted);
    --_leading-icon-color: var(--color-primary);
    --_hover-state-layer-color: var(--text);
    --_hover-state-layer-opacity: 0.08;
    --_pressed-state-layer-color: var(--text);
    --_pressed-state-layer-opacity: 0.12;
    --_icon-size: 18px;
    --_item-height: 48px;

    display: flex;
    align-items: center;
    gap: 12px;
    height: var(--_item-height);
    padding-inline: 12px 16px;
    cursor: pointer;
    position: relative;
    outline: none;
    background-color: var(--_container-color);
    color: var(--_label-color);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
    box-sizing: border-box;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    transition: background-color 100ms linear;
    list-style: none;
  }

  .md-select-option.selected {
    background-color: var(--_selected-container-color);
    color: var(--_selected-label-color);
  }

  .md-select-option.disabled {
    cursor: default;
    pointer-events: none;
    color: var(--_disabled-label-color);
    opacity: 0.38;
  }

  /* State layer */
  .md-select-option__state-layer {
    position: absolute;
    inset: 0;
    background-color: var(--_hover-state-layer-color);
    opacity: 0;
    transition: opacity 100ms linear;
    pointer-events: none;
  }

  .md-select-option:not(.disabled):hover .md-select-option__state-layer {
    opacity: var(--_hover-state-layer-opacity);
  }

  .md-select-option:not(.disabled):active .md-select-option__state-layer {
    opacity: var(--_pressed-state-layer-opacity);
  }

  .md-select-option:focus-visible {
    outline: 2px solid var(--focus-ring, var(--color-primary));
    outline-offset: -2px;
  }

  /* Leading icon slot (checkmark) */
  .md-select-option__leading-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--_icon-size);
    height: var(--_icon-size);
    flex-shrink: 0;
    color: var(--_leading-icon-color);
  }

  .md-select-option__check {
    width: var(--_icon-size);
    height: var(--_icon-size);
  }

  /* Headline text */
  .md-select-option__headline {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* High contrast mode */
  @media (forced-colors: active) {
    .md-select-option.selected {
      outline: 2px solid ButtonText;
    }

    .md-select-option.disabled {
      color: GrayText;
      opacity: 1;
    }
  }
</style>
