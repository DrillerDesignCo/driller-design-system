/**
 * Material Design 3 — TextField
 * Supports: filled (default), outlined
 *
 * Usage:
 *   <TextField label="Email" type="email" />
 *   <TextField variant="outlined" label="Name" supportingText="Enter your full name" />
 *   <TextField variant="filled" label="Bio" rows={4} />
 *   <TextField label="Username" maxLength={20} error errorText="Already taken" />
 */

interface Props {
  variant?: 'filled' | 'outlined';
  label?: string;
  placeholder?: string;
  value?: string;
  type?: any;
  disabled?: boolean;
  required?: boolean;
  error?: boolean;
  errorText?: string;
  supportingText?: string;
  maxLength?: number;
  rows?: number;
  name?: string;
  class?: string;
  [key: string]: any;
}

const {
  variant = 'filled',
  label,
  placeholder = ' ',
  value = '',
  type = 'text',
  disabled = false,
  required = false,
  error = false,
  errorText,
  supportingText,
  maxLength,
  rows,
  name,
  class: className,
  ...attrs
} = Astro.props;

const isTextarea = rows !== undefined && rows > 0;
const hasLabel = !!label;
const showSupportingText = !!(error && errorText) || !!supportingText;
const showCounter = maxLength !== undefined && maxLength > 0;

const fieldId = `md-tf-${Math.random().toString(36).slice(2, 9)}`;
---

<div
  class:list={[
    'md-text-field',
    `md-text-field--${variant}`,
    {
      'md-text-field--disabled': disabled,
      'md-text-field--error': error && !disabled,
      'md-text-field--no-label': !hasLabel,
      'md-text-field--textarea': isTextarea,
    },
    className,
  ]}
  data-variant={variant}
>
  <!-- Field container -->
  <div class="md-text-field__container-overflow">
    <div class="md-text-field__container">

      {/* Filled background + hover state layer */}
      {variant === 'filled' && (
        <>
          <div class="md-text-field__background" aria-hidden="true"></div>
          <div class="md-text-field__state-layer" aria-hidden="true"></div>
        </>
      )}

      {/* Outlined border */}
      {variant === 'outlined' && (
        <div class="md-text-field__outline" aria-hidden="true">
          <div class="md-text-field__outline-start"></div>
          <div class="md-text-field__outline-notch">
            {hasLabel && (
              <div class="md-text-field__outline-label">
                <span class="md-text-field__label md-text-field__label--floating">
                  {label}{required && <span class="md-text-field__asterisk" aria-hidden="true"> *</span>}
                </span>
              </div>
            )}
          </div>
          <div class="md-text-field__outline-end"></div>
        </div>
      )}

      <!-- Content row: leading | middle | trailing -->
      <div class="md-text-field__middle">

        {/* Floating label (filled only — lives in the middle) */}
        {hasLabel && (
          <div class="md-text-field__label-wrapper" aria-hidden="true">
            <span class="md-text-field__label md-text-field__label--resting">
              {label}{required && <span class="md-text-field__asterisk"> *</span>}
            </span>
            <span class="md-text-field__label md-text-field__label--floating">
              {label}{required && <span class="md-text-field__asterisk"> *</span>}
            </span>
          </div>
        )}

        <!-- Input / Textarea -->
        <div class="md-text-field__content">
          {isTextarea ? (
            <textarea
              id={fieldId}
              class="md-text-field__input"
              name={name || undefined}
              placeholder={placeholder}
              disabled={disabled}
              required={required}
              rows={rows}
              maxlength={maxLength !== undefined && maxLength > 0 ? maxLength : undefined}
              aria-invalid={error || undefined}
              aria-label={label || undefined}
              {...attrs}
            >{value}</textarea>
          ) : (
            <div class="md-text-field__input-wrapper">
              <input
                id={fieldId}
                class="md-text-field__input"
                type={type}
                name={name || undefined}
                value={value}
                placeholder={placeholder}
                disabled={disabled}
                required={required}
                maxlength={maxLength !== undefined && maxLength > 0 ? maxLength : undefined}
                aria-invalid={error || undefined}
                aria-label={label || undefined}
                {...attrs}
              />
            </div>
          )}
        </div>
      </div>
    </div>

    {/* Filled active-indicator bar */}
    {variant === 'filled' && (
      <div class="md-text-field__active-indicator" aria-hidden="true"></div>
    )}
  </div>

  <!-- Supporting / Error text + character counter -->
  {(showSupportingText || showCounter) && (
    <div class="md-text-field__supporting-text-row">
      <span class="md-text-field__supporting-text">
        {error && errorText ? errorText : supportingText}
      </span>
      {showCounter && (
        <span class="md-text-field__counter" aria-live="polite">
          {value.length}/{maxLength}
        </span>
      )}
    </div>
  )}
</div>

<script>
  // Floating label logic via JS (handles initial state + live updates)
  function initTextField(root: Document | Element = document) {
    root.querySelectorAll<HTMLElement>('.md-text-field').forEach((field) => {
      const input = field.querySelector<HTMLInputElement | HTMLTextAreaElement>(
        '.md-text-field__input'
      );
      const counter = field.querySelector<HTMLElement>('.md-text-field__counter');
      const maxLengthAttr = input?.getAttribute('maxlength');
      const maxLen = maxLengthAttr ? parseInt(maxLengthAttr, 10) : null;

      if (!input) return;

      function updateState() {
        const hasValue = input!.value.length > 0;
        // populated drives the floating label via CSS :has / data attr
        field.classList.toggle('md-text-field--populated', hasValue);

        if (counter && maxLen) {
          counter.textContent = `${input!.value.length}/${maxLen}`;
        }
      }

      function handleFocus() {
        field.classList.add('md-text-field--focused');
      }

      function handleBlur() {
        field.classList.remove('md-text-field--focused');
        updateState();
      }

      input.addEventListener('input', updateState);
      input.addEventListener('focus', handleFocus);
      input.addEventListener('blur', handleBlur);

      // Sync initial state
      updateState();
    });
  }

  document.addEventListener('DOMContentLoaded', () => initTextField());
  // Re-run for any dynamically added fields
  if (document.readyState !== 'loading') initTextField();
</script>

<style>
  /* ═══════════════════════════════════════════════════════
     TEXT FIELD — Design tokens (mapped from MD3)
     ═══════════════════════════════════════════════════════ */
  .md-text-field {
    /* Shape */
    --_container-shape-top-start: var(--md-text-field-container-shape-start-start, 4px);
    --_container-shape-top-end:   var(--md-text-field-container-shape-start-end, 4px);
    --_container-shape-bot-end:   var(--md-text-field-container-shape-end-end, 0px);
    --_container-shape-bot-start: var(--md-text-field-container-shape-end-start, 0px);

    /* Label */
    --_label-color:           var(--text-muted);
    --_label-font:            var(--font-body);
    --_label-size:            1rem;
    --_label-weight:          400;
    --_label-line-height:     1.5rem;
    --_label-populated-size:  0.75rem;
    --_label-populated-lh:    1rem;

    /* Content */
    --_content-color:         var(--text);
    --_content-font:          var(--font-body);
    --_content-size:          1rem;
    --_content-weight:        400;
    --_content-line-height:   1.5rem;

    /* Spacing */
    --_top-space:             1rem;
    --_bottom-space:          1rem;
    --_leading-space:         1rem;
    --_trailing-space:        1rem;
    --_with-label-top-space:  1.5rem;
    --_with-label-bot-space:  0.5rem;

    /* Supporting text */
    --_supporting-font:       var(--font-body);
    --_supporting-size:       0.75rem;
    --_supporting-weight:     400;
    --_supporting-lh:         1rem;
    --_supporting-color:      var(--text-muted);

    /* Filled variant tokens */
    --_filled-bg:             var(--surface-raised, rgba(127,127,127,.12));
    --_active-indicator-color: var(--line-strong);
    --_active-indicator-h:    1px;
    --_focus-indicator-color: var(--color-primary);
    --_focus-indicator-h:     2px;

    /* Outlined variant tokens */
    --_outline-color:         var(--line-strong);
    --_outline-width:         1px;
    --_focus-outline-color:   var(--color-primary);
    --_focus-outline-width:   2px;
    --_outline-label-padding: 4px;

    /* Hover tokens */
    --_hover-label-color:     var(--text);
    --_hover-indicator-color: var(--text);
    --_hover-outline-color:   var(--text);

    /* Error tokens */
    --_error-color:           var(--md-sys-color-error);
    --_error-label-color:     var(--md-sys-color-error);
    --_error-indicator-color: var(--md-sys-color-error);
    --_error-outline-color:   var(--md-sys-color-error);
    --_error-supporting-color: var(--md-sys-color-error);

    /* Disabled tokens */
    --_disabled-opacity:      0.38;

    display: inline-flex;
    flex-direction: column;
    outline: none;
    resize: both;
    text-align: start;
    -webkit-tap-highlight-color: transparent;
    vertical-align: top;
    min-width: 200px;
  }

  /* ── Field structure ───────────────────── */
  .md-text-field__container-overflow {
    border-start-start-radius: var(--_container-shape-top-start);
    border-start-end-radius:   var(--_container-shape-top-end);
    border-end-end-radius:     var(--_container-shape-bot-end);
    border-end-start-radius:   var(--_container-shape-bot-start);
    display: flex;
    flex-direction: column;
    height: 100%;
    position: relative;
  }

  .md-text-field__container {
    align-items: center;
    border-radius: inherit;
    display: flex;
    flex: 1;
    min-height: 56px;
    min-width: min-content;
    position: relative;
    cursor: text;
  }

  .md-text-field--disabled .md-text-field__container {
    cursor: default;
  }

  /* ── Middle section ────────────────────── */
  .md-text-field__middle {
    display: flex;
    flex: 1;
    flex-direction: column;
    position: relative;
    align-self: stretch;
    min-width: 0;
  }

  /* ── Content area ──────────────────────── */
  .md-text-field__content {
    display: flex;
    flex: 1;
    align-items: center;
    color: var(--_content-color);
    font-family: var(--_content-font);
    font-size: var(--_content-size);
    font-weight: var(--_content-weight);
    line-height: var(--_content-line-height);
    /* Content fades in when label floats (when no-label OR focused OR populated) */
    opacity: 0;
    transition: opacity 83ms cubic-bezier(0.2, 0, 0, 1);
  }

  .md-text-field--no-label .md-text-field__content,
  .md-text-field--focused .md-text-field__content,
  .md-text-field--populated .md-text-field__content,
  .md-text-field:focus-within .md-text-field__content,
  .md-text-field:has(.md-text-field__input:not(:placeholder-shown)) .md-text-field__content {
    opacity: 1;
    transition-delay: 67ms;
  }

  .md-text-field--disabled .md-text-field__content {
    transition: none;
    opacity: var(--_disabled-opacity);
    color: var(--_content-color);
  }

  /* Input wrapper (for inline input) */
  .md-text-field__input-wrapper {
    display: flex;
    flex: 1;
    min-width: 0;
  }

  /* ── Native input / textarea ───────────── */
  .md-text-field__input {
    all: unset;
    color: currentColor;
    display: block;
    font: inherit;
    width: 100%;
    overflow-x: hidden;
    text-align: inherit;
    caret-color: var(--_focus-indicator-color);
    box-sizing: border-box;
    padding-top: var(--_top-space);
    padding-bottom: var(--_bottom-space);
    padding-inline-start: var(--_leading-space);
    padding-inline-end: var(--_trailing-space);
  }

  .md-text-field--no-label .md-text-field__input {
    padding-top: var(--_top-space);
    padding-bottom: var(--_bottom-space);
  }

  .md-text-field__input::placeholder {
    color: var(--_label-color);
    opacity: 1;
  }

  .md-text-field__input::-webkit-calendar-picker-indicator { display: none; }
  .md-text-field__input::-webkit-search-decoration,
  .md-text-field__input::-webkit-search-cancel-button { display: none; }

  /* textarea */
  .md-text-field--textarea .md-text-field__input {
    resize: none;
    height: auto;
    overflow: auto;
  }

  /* ── Floating label ────────────────────── */
  .md-text-field__label-wrapper {
    pointer-events: none;
    position: absolute;
    inset: 0;
    text-align: initial;
  }

  .md-text-field__label {
    box-sizing: border-box;
    color: var(--_label-color);
    font-family: var(--_label-font);
    font-size: var(--_label-size);
    font-weight: var(--_label-weight);
    line-height: var(--_label-line-height);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 100%;
    width: min-content;
    z-index: 1;
    transition:
      font-size 150ms cubic-bezier(0.2, 0, 0, 1),
      top       150ms cubic-bezier(0.2, 0, 0, 1),
      color     150ms cubic-bezier(0.2, 0, 0, 1);
  }

  /* Resting label: vertically centered in the field */
  .md-text-field__label--resting {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    padding-inline-start: var(--_leading-space);
  }

  /* Floating label: small, top of filled field */
  .md-text-field__label--floating {
    position: absolute;
    top: var(--_with-label-top-space);
    transform: translateY(-100%);
    font-size: var(--_label-populated-size);
    line-height: var(--_label-populated-lh);
    padding-inline-start: var(--_leading-space);
    opacity: 0;
    transition:
      font-size 150ms cubic-bezier(0.2, 0, 0, 1),
      opacity   150ms cubic-bezier(0.2, 0, 0, 1);
  }

  /* When no initial value, hide floating, show resting */
  .md-text-field__label--resting { opacity: 1; }

  /* When focused or populated → hide resting, show floating */
  .md-text-field--focused .md-text-field__label--resting,
  .md-text-field--populated .md-text-field__label--resting,
  .md-text-field:focus-within .md-text-field__label--resting,
  .md-text-field:has(.md-text-field__input:not(:placeholder-shown)) .md-text-field__label--resting {
    opacity: 0;
  }

  .md-text-field--focused .md-text-field__label--floating,
  .md-text-field--populated .md-text-field__label--floating,
  .md-text-field:focus-within .md-text-field__label--floating,
  .md-text-field:has(.md-text-field__input:not(:placeholder-shown)) .md-text-field__label--floating {
    opacity: 1;
  }

  /* When no label, hide both */
  .md-text-field--no-label .md-text-field__label { display: none; }

  /* Label colours */
  .md-text-field:hover .md-text-field__label { color: var(--_hover-label-color); }
  .md-text-field--focused .md-text-field__label { color: var(--_focus-indicator-color); }
  .md-text-field--error .md-text-field__label { color: var(--_error-label-color); }
  .md-text-field--disabled .md-text-field__label {
    color: var(--_label-color);
    opacity: var(--_disabled-opacity);
  }

  /* Filled — extra padding to push input down when label is present */
  .md-text-field--filled:not(.md-text-field--no-label) .md-text-field__input {
    padding-top: calc(var(--_with-label-top-space) + var(--_label-populated-lh));
    padding-bottom: var(--_with-label-bot-space);
  }

  .md-text-field--filled:not(.md-text-field--no-label).md-text-field--textarea
    .md-text-field__input {
    margin-top: calc(var(--_with-label-top-space) + var(--_label-populated-lh));
    padding-top: 0;
  }

  /* ── Filled variant ────────────────────── */
  .md-text-field--filled .md-text-field__container-overflow {
    --_container-shape-bot-end:   0px;
    --_container-shape-bot-start: 0px;
  }

  .md-text-field--filled .md-text-field__container-overflow {
    border-radius:
      var(--_container-shape-top-start)
      var(--_container-shape-top-end)
      0 0;
  }

  .md-text-field__background {
    background: var(--_filled-bg);
    border-radius: inherit;
    inset: 0;
    pointer-events: none;
    position: absolute;
  }

  .md-text-field__state-layer {
    background: transparent;
    border-radius: inherit;
    inset: 0;
    pointer-events: none;
    position: absolute;
    transition: background 200ms;
    visibility: hidden;
  }

  .md-text-field--filled:not(.md-text-field--disabled):hover .md-text-field__state-layer {
    visibility: visible;
    background: color-mix(in srgb, var(--text) 8%, transparent);
  }

  .md-text-field--disabled .md-text-field__background {
    opacity: var(--_disabled-opacity);
  }

  /* Active indicator (bottom border on filled) */
  .md-text-field__active-indicator {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .md-text-field__active-indicator::before,
  .md-text-field__active-indicator::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
  }

  /* Resting indicator */
  .md-text-field__active-indicator::before {
    border-bottom: var(--_active-indicator-h) solid var(--_active-indicator-color);
  }

  /* Focus indicator */
  .md-text-field__active-indicator::after {
    border-bottom: var(--_focus-indicator-h) solid var(--_focus-indicator-color);
    opacity: 0;
    transition: opacity 150ms cubic-bezier(0.2, 0, 0, 1);
  }

  .md-text-field--filled:hover .md-text-field__active-indicator::before {
    border-bottom-color: var(--_hover-indicator-color);
    border-bottom-width: var(--_active-indicator-h);
  }

  .md-text-field--focused .md-text-field__active-indicator::after {
    opacity: 1;
  }

  .md-text-field--error .md-text-field__active-indicator::before {
    border-bottom-color: var(--_error-indicator-color);
  }

  .md-text-field--error.md-text-field--focused .md-text-field__active-indicator::after {
    border-bottom-color: var(--_error-indicator-color);
    opacity: 1;
  }

  .md-text-field--disabled .md-text-field__active-indicator::before {
    border-bottom-color: var(--_active-indicator-color);
    opacity: var(--_disabled-opacity);
  }

  /* ── Outlined variant ──────────────────── */
  .md-text-field--outlined .md-text-field__container-overflow {
    border-radius: 4px;
  }

  .md-text-field__outline {
    border-color: var(--_outline-color);
    border-radius: inherit;
    display: flex;
    pointer-events: none;
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .md-text-field__outline-start,
  .md-text-field__outline-end {
    border: var(--_outline-width) solid currentColor;
    border-radius: inherit;
    box-sizing: border-box;
    position: relative;
    transition: border-width 150ms cubic-bezier(0.2, 0, 0, 1);
  }

  .md-text-field__outline-start {
    border-inline-end: none;
    border-start-end-radius: 0;
    border-end-end-radius: 0;
    min-width: 12px;
  }

  .md-text-field__outline-end {
    border-inline-start: none;
    border-start-start-radius: 0;
    border-end-start-radius: 0;
    flex-grow: 1;
  }

  .md-text-field__outline-notch {
    border: var(--_outline-width) solid currentColor;
    border-inline: none;
    border-top: none;
    box-sizing: border-box;
    position: relative;
    align-items: flex-start;
    display: flex;
    padding-inline: var(--_outline-label-padding);
    transition: border-width 150ms cubic-bezier(0.2, 0, 0, 1);
    /* The notch top border is optionally hidden when label floats */
    border-top-style: solid;
  }

  /* Hide top notch border when label is visible (focused/populated) */
  .md-text-field--focused .md-text-field__outline-notch,
  .md-text-field--populated .md-text-field__outline-notch,
  .md-text-field:focus-within .md-text-field__outline-notch,
  .md-text-field:has(.md-text-field__input:not(:placeholder-shown)) .md-text-field__outline-notch {
    border-top-color: transparent;
  }

  /* No label: collapse notch */
  .md-text-field--no-label .md-text-field__outline-notch {
    display: none;
  }

  .md-text-field__outline-label {
    display: flex;
    max-width: 100%;
    transform: translateY(calc(-50% - var(--_outline-label-padding)));
  }

  /* Outlined floating label — lives inside outline notch, always floating */
  .md-text-field--outlined .md-text-field__label--floating {
    position: static;
    transform: none;
    top: auto;
    padding-inline-start: 0;
    opacity: 0;
    font-size: var(--_label-populated-size);
    line-height: var(--_label-populated-lh);
  }

  .md-text-field--outlined.md-text-field--focused .md-text-field__label--floating,
  .md-text-field--outlined.md-text-field--populated .md-text-field__label--floating,
  .md-text-field--outlined:focus-within .md-text-field__label--floating,
  .md-text-field--outlined:has(.md-text-field__input:not(:placeholder-shown)) .md-text-field__label--floating {
    opacity: 1;
  }

  /* Outlined resting label — lives in label-wrapper, centered vertically */
  .md-text-field--outlined .md-text-field__label--resting {
    padding-inline-start: var(--_leading-space);
  }

  .md-text-field--outlined.md-text-field--focused .md-text-field__label--resting,
  .md-text-field--outlined.md-text-field--populated .md-text-field__label--resting,
  .md-text-field--outlined:focus-within .md-text-field__label--resting,
  .md-text-field--outlined:has(.md-text-field__input:not(:placeholder-shown)) .md-text-field__label--resting {
    opacity: 0;
  }

  /* Outlined input — needs to clear the outline element */
  .md-text-field--outlined .md-text-field__input {
    padding-top: var(--_top-space);
    padding-bottom: var(--_bottom-space);
  }

  /* Outlined states */
  .md-text-field--outlined:hover .md-text-field__outline {
    border-color: var(--_hover-outline-color);
    color: var(--_hover-outline-color);
  }

  .md-text-field--outlined.md-text-field--focused .md-text-field__outline,
  .md-text-field--outlined.md-text-field--focused .md-text-field__outline-start,
