interface Props {
  disabled?: boolean;
  selected?: boolean;
  label?: string;
  noCheckmark?: boolean;
  class?: string;
}

const {
  disabled = false,
  selected = false,
  label = '',
  noCheckmark = false,
  class: className,
  ...attrs
} = Astro.props;

const hasLabel = label !== '';
---

<button
  class:list={['md-segmented-button', {
    'md-segmented-button--selected': selected,
    'md-segmented-button--unselected': !selected,
    'md-segmented-button--with-label': hasLabel,
    'md-segmented-button--without-label': !hasLabel,
    'md-segmented-button--with-checkmark': !noCheckmark,
    'md-segmented-button--without-checkmark': noCheckmark,
  }, className]}
  aria-pressed={selected ? 'true' : 'false'}
  disabled={disabled || undefined}
  tabindex={disabled ? -1 : 0}
  {...attrs}
>
  <span class="md-segmented-button__outline"></span>
  <span class="md-segmented-button__leading" aria-hidden="true">
    <span class="md-segmented-button__graphic">
      <svg class="md-segmented-button__checkmark" viewBox="0 0 24 24">
        <path class="md-segmented-button__checkmark-path" fill="none" d="M1.73,12.91 8.1,19.28 22.79,4.59"></path>
      </svg>
      {!hasLabel && (
        <span class="md-segmented-button__icon">
          <slot name="icon" />
        </span>
      )}
      {hasLabel && (
        <span class="md-segmented-button__icon">
          <slot name="icon" />
        </span>
      )}
    </span>
  </span>
  {hasLabel && <span class="md-segmented-button__label-text">{label}</span>}
  <span class="md-segmented-button__touch"></span>
</button>

<style>
  /* ── Button reset & layout ── */
  .md-segmented-button {
    appearance: none;
    border: none;
    background: transparent;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;

    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    border-radius: inherit;
    padding-inline: 12px;
    height: 100%;
    gap: 0;

    /* Ripple */
    &::after {
      content: '';
      position: absolute;
      inset: 0;
      background: currentColor;
      opacity: 0;
      transition: opacity 0.2s ease;
      border-radius: inherit;
      pointer-events: none;
    }

    &:hover::after {
      opacity: 0.08;
    }

    &:active::after {
      opacity: 0.16;
    }

    &:focus-visible {
      outline: 2px solid var(--color-primary, #6750a4);
      outline-offset: -2px;
      z-index: 2;
    }
  }

  /* ── Selected state ── */
  .md-segmented-button--selected {
    background: var(--surface-container-highest, var(--surface-dim, #e6e0e9));
  }

  .md-segmented-button--selected .md-segmented-button__label-text,
  .md-segmented-button--selected .md-segmented-button__icon {
    color: var(--color-primary, #6750a4);
  }

  .md-segmented-button--unselected .md-segmented-button__label-text,
  .md-segmented-button--unselected .md-segmented-button__icon {
    color: var(--text, #1d1b20);
  }

  /* ── Disabled ── */
  .md-segmented-button:disabled {
    cursor: not-allowed;
    pointer-events: none;
  }

  .md-segmented-button:disabled .md-segmented-button__label-text,
  .md-segmented-button:disabled .md-segmented-button__icon {
    opacity: 0.38;
  }

  .md-segmented-button:disabled .md-segmented-button__outline {
    opacity: 0.12;
  }

  /* ── Outline ── */
  .md-segmented-button__outline {
    border-radius: inherit;
    border: 1px solid var(--line-strong, var(--line, #79747e));
    position: absolute;
    inset: 0 -0.5px;
    pointer-events: none;
  }

  /* ── Leading area ── */
  .md-segmented-button__leading {
    display: flex;
    align-items: center;
  }

  .md-segmented-button__graphic {
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  /* ── Checkmark ── */
  .md-segmented-button__checkmark {
    width: 18px;
    height: 18px;
    display: none;
  }

  .md-segmented-button__checkmark-path {
    stroke: var(--color-primary, #6750a4);
    stroke-width: 2;
    stroke-dasharray: 29.7833385;
    stroke-dashoffset: 29.7833385;
  }

  /* Show and animate checkmark when selected + with-checkmark */
  .md-segmented-button--selected.md-segmented-button--with-checkmark .md-segmented-button__checkmark {
    display: block;
  }

  .md-segmented-button--selected.md-segmented-button--with-checkmark .md-segmented-button__checkmark-path {
    animation: md-segmented-button-checkmark-draw 150ms ease forwards;
  }

  @keyframes md-segmented-button-checkmark-draw {
    from {
      stroke-dashoffset: 29.7833385;
    }
    to {
      stroke-dashoffset: 0;
    }
  }

  /* ── Icon slot ── */
  .md-segmented-button__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    transition: opacity 0.15s ease, width 0.15s ease;
  }

  /* Hide icon when selected + has label + has checkmark (checkmark replaces it) */
  .md-segmented-button--selected.md-segmented-button--with-label.md-segmented-button--with-checkmark .md-segmented-button__icon {
    opacity: 0;
    width: 0;
    overflow: hidden;
  }

  /* Add margin between leading graphic and label */
  .md-segmented-button--with-label .md-segmented-button__leading {
    margin-inline-end: 8px;
  }

  /* When no checkmark and no icon, don't show the leading area */
  .md-segmented-button--without-checkmark .md-segmented-button__checkmark {
    display: none;
  }

  /* ── Label ── */
  .md-segmented-button__label-text {
    font-family: var(--font-body, system-ui, sans-serif);
    font-size: var(--label-text-size, 14px);
    font-weight: 500;
    letter-spacing: 0.1px;
    line-height: 1.3;
    white-space: nowrap;
    user-select: none;
  }

  /* ── Touch target ── */
  .md-segmented-button__touch {
    position: absolute;
    inset: 50% 0 auto;
    transform: translateY(-50%);
    height: 48px;
    width: 100%;
    pointer-events: none;
  }
</style>
