interface Props {
  value?: string;
  class?: string;
}

const {
  value,
  class: className,
  ...attrs
} = Astro.props;
---

<div class:list={['md-badge', { 'md-badge--large': !!value }, className]} {...attrs}>
  {value && <p class="md-badge__value">{value}</p>}
</div>

<style>
  .md-badge {
    position: absolute;
    inset-inline-start: 50%;
    top: 0;
    transform: translateX(-50%) translateY(-50%);

    /* Dot (no value) */
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background-color: var(--color-primary);

    display: flex;
    align-items: center;
    justify-content: center;

    transition: width 0.15s ease, height 0.15s ease, padding 0.15s ease;
  }

  /* Large pill (has value) */
  .md-badge--large {
    width: auto;
    height: 16px;
    min-width: 16px;
    padding-inline: 4px;
  }

  .md-badge__value {
    margin: 0;
    padding: 0;
    color: var(--color-on-primary);
    font-family: var(--font-body, sans-serif);
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    white-space: nowrap;
  }
</style>
