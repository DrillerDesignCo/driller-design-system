/**
 * Material Design 3 — Chip
 * Supports: assist, filter, input, suggestion
 *
 * Usage:
 *   <Chip variant="assist" label="Assist" />
 *   <Chip variant="filter" label="Genre" selected />
 *   <Chip variant="input" label="Tag" removable />
 *   <Chip variant="suggestion" label="Idea" href="/path" />
 */

interface Props {
  variant?: 'assist' | 'filter' | 'input' | 'suggestion';
  label: string;
  selected?: boolean;
  disabled?: boolean;
  elevated?: boolean;
  removable?: boolean;
  href?: string;
  class?: string;
  [key: string]: any;
}

const {
  variant = 'assist',
  label,
  selected = false,
  disabled = false,
  elevated = false,
  removable = false,
  href,
  class: className,
  ...attrs
} = Astro.props;

const isLink = !!href;
const isFilter = variant === 'filter';
const isInput = variant === 'input';

// The primary action element tag
const PrimaryTag = isLink ? 'a' : 'button';

const containerClasses = [
  'md-chip__container',
  `md-chip--${variant}`,
  {
    'md-chip--elevated': elevated,
    'md-chip--selected': selected,
    'md-chip--disabled': disabled,
    'md-chip--has-trailing': isInput || (isFilter && removable),
  },
];
---

<span
  class:list={['md-chip', className]}
  data-variant={variant}
  {...attrs}
>
  <span class:list={containerClasses}>
    {/* Outline layer */}
    <span class="md-chip__outline" aria-hidden="true"></span>

    {/* Elevated shadow layer (for elevated chips) */}
    {elevated && <span class="md-chip__elevation" aria-hidden="true"></span>}

    {/* Ripple */}
    <span class="md-ripple" aria-hidden="true"></span>

    {/* Primary action */}
    <PrimaryTag
      class="md-chip__primary-action"
      {...isLink ? { href, tabindex: disabled ? -1 : undefined } : {
        type: 'button',
        disabled: disabled || undefined,
        'aria-pressed': isFilter ? (selected ? 'true' : 'false') : undefined,
      }}
      aria-label={label}
    >
      {/* Leading icon area */}
      <span class="md-chip__leading-icon" aria-hidden="true">
        {isFilter && selected ? (
          <svg class="md-chip__checkmark" viewBox="0 0 18 18" aria-hidden="true">
            <path d="M6.75012 12.1274L3.62262 8.99988L2.55762 10.0574L6.75012 14.2499L15.7501 5.24988L14.6926 4.19238L6.75012 12.1274Z" />
          </svg>
        ) : (
          <slot name="icon" />
        )}
      </span>

      {/* Label */}
      <span class="md-chip__label">
        <span class="md-chip__label-text">{label}</span>
      </span>

      {/* Touch target */}
      <span class="md-chip__touch" aria-hidden="true"></span>
    </PrimaryTag>

    {/* Trailing remove button — filter (removable) + input chips */}
    {(isInput || (isFilter && removable)) && (
      <button
        type="button"
        class="md-chip__trailing-action"
        aria-label={`Remove ${label}`}
        disabled={disabled || undefined}
        tabindex={disabled ? -1 : undefined}
      >
        <span class="md-chip__trailing-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
            <path d="M19 6.41 17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
          </svg>
        </span>
        <span class="md-ripple" aria-hidden="true"></span>
      </button>
    )}
  </span>
</span>

{/* Filter chip toggle selection */}
{isFilter && (
  <script>
    document.querySelectorAll<HTMLElement>('.md-chip[data-variant="filter"]').forEach((chip) => {
      const container = chip.querySelector<HTMLElement>('.md-chip__container');
      const btn = chip.querySelector<HTMLButtonElement>('.md-chip__primary-action');
      if (!btn || !container) return;

      btn.addEventListener('click', () => {
        const isSelected = container.classList.toggle('md-chip--selected');
        btn.setAttribute('aria-pressed', String(isSelected));

        // Swap icon vs checkmark
        const leadingIcon = container.querySelector<HTMLElement>('.md-chip__leading-icon');
        if (!leadingIcon) return;
        const checkmark = leadingIcon.querySelector('.md-chip__checkmark');
        const iconSlot = leadingIcon.querySelector<HTMLSlotElement>('slot[name="icon"]');
        if (isSelected) {
          if (!checkmark) {
            const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
            svg.setAttribute('class', 'md-chip__checkmark');
            svg.setAttribute('viewBox', '0 0 18 18');
            svg.setAttribute('aria-hidden', 'true');
            const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
            path.setAttribute('d', 'M6.75012 12.1274L3.62262 8.99988L2.55762 10.0574L6.75012 14.2499L15.7501 5.24988L14.6926 4.19238L6.75012 12.1274Z');
            svg.appendChild(path);
            leadingIcon.insertBefore(svg, leadingIcon.firstChild);
          }
          if (iconSlot) iconSlot.style.display = 'none';
        } else {
          if (checkmark) checkmark.remove();
          if (iconSlot) iconSlot.style.display = '';
        }
      });
    });
  </script>
)}

{/* Input chip remove */}
{isInput && (
  <script>
    document.querySelectorAll<HTMLElement>('.md-chip[data-variant="input"]').forEach((chip) => {
      const removeBtn = chip.querySelector<HTMLButtonElement>('.md-chip__trailing-action');
      if (!removeBtn) return;
      removeBtn.addEventListener('click', () => {
        chip.dispatchEvent(new CustomEvent('remove', { bubbles: true }));
        chip.remove();
      });
    });
  </script>
)}

<style>
  /* ═══════════════════════════════════════
     CHIP — Host wrapper
     ═══════════════════════════════════════ */
  .md-chip {
    display: inline-flex;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  /* ═══════════════════════════════════════
     CHIP — Container
     ═══════════════════════════════════════ */
  .md-chip__container {
    --_height: 32px;
    --_shape: 9999px;
    --_leading-space: 16px;
    --_trailing-space: 16px;
    --_with-leading-icon-leading-space: 8px;
    --_with-trailing-icon-trailing-space: 8px;
    --_icon-size: 18px;
    --_icon-label-space: 8px;

    /* Default (unselected) token values — using Driller design tokens */
    --_container-color: transparent;
    --_label-text-color: var(--text);
    --_label-text-font: var(--font-body);
    --_label-text-size: 0.875rem;
    --_label-text-weight: 500;
    --_outline-color: var(--line-strong);
    --_outline-width: 1px;
    --_leading-icon-color: var(--text-muted);
    --_trailing-icon-color: var(--text-muted);

    /* Hover / focus / pressed */
    --_hover-label-text-color: var(--text);
    --_focus-label-text-color: var(--text);
    --_pressed-label-text-color: var(--text);
    --_hover-leading-icon-color: var(--text);
    --_focus-leading-icon-color: var(--text);
    --_pressed-leading-icon-color: var(--text);
    --_hover-trailing-icon-color: var(--text);
    --_focus-trailing-icon-color: var(--text);
    --_pressed-trailing-icon-color: var(--text);

    /* Disabled */
    --_disabled-label-text-color: var(--text-muted);
    --_disabled-label-text-opacity: 0.38;
    --_disabled-outline-color: var(--line);
    --_disabled-outline-opacity: 0.12;
    --_disabled-leading-icon-color: var(--text-muted);
    --_disabled-leading-icon-opacity: 0.38;
    --_disabled-trailing-icon-color: var(--text-muted);
    --_disabled-trailing-icon-opacity: 0.38;

    /* Selected */
    --_selected-container-color: var(--surface-raised, color-mix(in srgb, var(--color-primary) 12%, transparent));
    --_selected-label-text-color: var(--color-primary);
    --_selected-leading-icon-color: var(--color-primary);
    --_selected-trailing-icon-color: var(--color-primary);
    --_selected-hover-label-text-color: var(--color-primary);
    --_selected-focus-label-text-color: var(--color-primary);
    --_selected-pressed-label-text-color: var(--color-primary);
    --_selected-hover-leading-icon-color: var(--color-primary);
    --_selected-focus-leading-icon-color: var(--color-primary);
    --_selected-pressed-leading-icon-color: var(--color-primary);
    --_selected-hover-trailing-icon-color: var(--color-primary);
    --_selected-focus-trailing-icon-color: var(--color-primary);
    --_selected-pressed-trailing-icon-color: var(--color-primary);
    --_selected-outline-width: 0px;
    --_disabled-selected-container-color: var(--surface);
    --_disabled-selected-container-opacity: 0.12;

    /* Elevated */
    --_elevated-container-color: var(--surface-raised, var(--surface));
    --_elevated-container-elevation: 1;
    --_elevated-hover-container-elevation: 2;
    --_elevated-focus-container-elevation: 1;
    --_elevated-pressed-container-elevation: 1;
    --_elevated-disabled-container-elevation: 0;
    --_elevated-disabled-container-color: var(--surface);
    --_elevated-disabled-container-opacity: 0.12;
    --_elevated-container-shadow-color: rgba(0, 0, 0, 0.3);

    border-radius: var(--_shape);
    box-sizing: border-box;
    display: flex;
    height: var(--_height);
    position: relative;
    width: 100%;
  }

  .md-chip__container::before {
    border-radius: inherit;
    content: '';
    inset: 0;
    pointer-events: none;
    position: absolute;
    background: var(--_container-color);
  }

  .md-chip__container:not(.md-chip--disabled) {
    cursor: pointer;
  }

  .md-chip__container.md-chip--disabled {
    pointer-events: none;
  }

  /* ═══════════════════════════════════════
     CHIP — Outline
     ═══════════════════════════════════════ */
  .md-chip__outline {
    border: var(--_outline-width) solid var(--_outline-color);
    border-radius: inherit;
    inset: 0;
    pointer-events: none;
    position: absolute;
  }

  .md-chip__container:focus-within .md-chip__outline {
    border-color: var(--color-primary);
  }

  .md-chip--disabled .md-chip__outline {
    border-color: var(--_disabled-outline-color);
    opacity: var(--_disabled-outline-opacity);
  }

  /* ═══════════════════════════════════════
     CHIP — Ripple
     ═══════════════════════════════════════ */
  .md-ripple {
    border-radius: inherit;
    inset: 0;
    pointer-events: none;
    position: absolute;
    overflow: hidden;
  }

  /* ═══════════════════════════════════════
     CHIP — Primary action
     ═══════════════════════════════════════ */
  .md-chip__primary-action {
    align-items: baseline;
    appearance: none;
    background: none;
    border: none;
    border-radius: inherit;
    display: flex;
    min-width: 0;
    outline: none;
    padding: 0;
    padding-inline-start: var(--_leading-space);
    padding-inline-end: var(--_trailing-space);
    position: relative;
    text-decoration: none;
    cursor: inherit;
    color: inherit;
    font: inherit;
  }

  .md-chip__primary-action:focus-visible {
    outline: 3px solid var(--focus-ring, var(--color-primary));
    outline-offset: 2px;
    border-radius: var(--_shape);
  }

  a.md-chip__primary-action,
  button.md-chip__primary-action:not(:disabled, [aria-disabled='true']) {
    cursor: pointer;
  }

  /* ═══════════════════════════════════════
     CHIP — Has leading icon adjustments
     ═══════════════════════════════════════ */
  .md-chip__container:has(.md-chip__leading-icon > *) .md-chip__primary-action,
  .md-chip--selected .md-chip__primary-action {
    padding-inline-start: var(--_with-leading-icon-leading-space);
  }

  /* ═══════════════════════════════════════
     CHIP — Has trailing action adjustments
     ═══════════════════════════════════════ */
  .md-chip--has-trailing .md-chip__primary-action {
    padding-inline-end: 0;
  }

  /* ═══════════════════════════════════════
     CHIP — Touch target
     ═══════════════════════════════════════ */
  .md-chip__touch {
    height: 48px;
    inset: 50% 0 0;
    position: absolute;
    transform: translateY(-50%);
    width: 100%;
  }

  /* ═══════════════════════════════════════
     CHIP — Leading icon
     ═══════════════════════════════════════ */
  .md-chip__leading-icon {
    align-self: center;
    display: flex;
    fill: currentColor;
    color: var(--_leading-icon-color);
    position: relative;
    z-index: 1;
  }

  .md-chip__leading-icon ::slotted(*),
  .md-chip__leading-icon svg {
    font-size: var(--_icon-size);
    height: var(--_icon-size);
    width: var(--_icon-size);
    margin-inline-end: var(--_icon-label-space);
    flex-shrink: 0;
  }

  :where(:hover) .md-chip__leading-icon {
    color: var(--_hover-leading-icon-color);
  }

  :where(:focus-within) .md-chip__leading-icon {
    color: var(--_focus-leading-icon-color);
  }

  :where(:active) .md-chip__leading-icon {
    color: var(--_pressed-leading-icon-color);
  }

  .md-chip--disabled .md-chip__leading-icon {
    color: var(--_disabled-leading-icon-color);
    opacity: var(--_disabled-leading-icon-opacity);
  }

  /* ═══════════════════════════════════════
     CHIP — Checkmark (filter selected)
     ═══════════════════════════════════════ */
  .md-chip__checkmark {
    height: var(--_icon-size);
    width: var(--_icon-size);
    fill: currentColor;
    flex-shrink: 0;
    margin-inline-end: var(--_icon-label-space);
  }

  /* ═══════════════════════════════════════
     CHIP — Label
     ═══════════════════════════════════════ */
  .md-chip__label {
    align-items: center;
    color: var(--_label-text-color);
    display: flex;
    font-family: var(--_label-text-font);
    font-size: var(--_label-text-size);
    font-weight: var(--_label-text-weight);
    height: 100%;
    overflow: hidden;
    user-select: none;
    z-index: 1;
  }

  .md-chip__label-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :where(:hover) .md-chip__label {
    color: var(--_hover-label-text-color);
  }

  :where(:focus-within) .md-chip__label {
    color: var(--_focus-label-text-color);
  }

  :where(:active) .md-chip__label {
    color: var(--_pressed-label-text-color);
  }

  .md-chip--disabled .md-chip__label {
    color: var(--_disabled-label-text-color);
    opacity: var(--_disabled-label-text-opacity);
  }

  /* ═══════════════════════════════════════
     CHIP — Trailing action (remove button)
     ═══════════════════════════════════════ */
  .md-chip__trailing-action {
    align-items: center;
    justify-content: center;
    appearance: none;
    background: none;
    border: none;
    border-radius: inherit;
    cursor: inherit;
    display: flex;
    outline: none;
    padding: 0;
    padding-inline-start: var(--_icon-label-space);
    padding-inline-end: var(--_with-trailing-icon-trailing-space, 8px);
    position: relative;
  }

  .md-chip__trailing-action:focus-visible {
    outline: 3px solid var(--focus-ring, var(--color-primary));
    outline-offset: 2px;
    border-radius: 50%;
  }

  .md-chip__trailing-icon {
    color: var(--_trailing-icon-color);
    display: flex;
    height: var(--_icon-size);
    width: var(--_icon-size);
    z-index: 1;
  }

  .md-chip__trailing-icon svg {
    fill: currentColor;
  }

  :where(:hover) .md-chip__trailing-icon {
    color: var(--_hover-trailing-icon-color);
  }

  :where(:focus-within) .md-chip__trailing-icon {
    color: var(--_focus-trailing-icon-color);
  }

  :where(:active) .md-chip__trailing-icon {
    color: var(--_pressed-trailing-icon-color);
  }

  .md-chip--disabled .md-chip__trailing-icon {
    color: var(--_disabled-trailing-icon-color);
    opacity: var(--_disabled-trailing-icon-opacity);
  }

  /* ═══════════════════════════════════════
     CHIP — Selected state
     ═══════════════════════════════════════ */
  .md-chip--selected::before {
    background: var(--_selected-container-color);
  }

  .md-chip--selected .md-chip__outline {
    border-width: var(--_selected-outline-width);
  }

  .md-chip--selected .md-chip__label {
    color: var(--_selected-label-text-color);
  }

  .md-chip--selected:hover .md-chip__label {
    color: var(--_selected-hover-label-text-color);
  }

  .md-chip--selected:focus-within .md-chip__label {
    color: var(--_selected-focus-label-text-color);
  }

  .md-chip--selected:active .md-chip__label {
    color: var(--_selected-pressed-label-text-color);
  }

  .md-chip--selected .md-chip__leading-icon {
    color: var(--_selected-leading-icon-color);
  }

  .md-chip--selected:hover .md-chip__leading-icon {
    color: var(--_selected-hover-leading-icon-color);
  }

  .md-chip--selected:focus-within .md-chip__leading-icon {
    color: var(--_selected-focus-leading-icon-color);
  }

  .md-chip--selected:active .md-chip__leading-icon {
    color: var(--_selected-pressed-leading-icon-color);
  }

  .md-chip--selected .md-chip__trailing-icon {
    color: var(--_selected-trailing-icon-color);
  }

  .md-chip--selected:hover .md-chip__trailing-icon {
    color: var(--_selected-hover-trailing-icon-color);
  }

  .md-chip--selected:focus-within .md-chip__trailing-icon {
    color: var(--_selected-focus-trailing-icon-color);
  }

  .md-chip--selected:active .md-chip__trailing-icon {
    color: var(--_selected-pressed-trailing-icon-color);
  }

  .md-chip--selected.md-chip--disabled::before {
    background: var(--_disabled-selected-container-color);
    opacity: var(--_disabled-selected-container-opacity);
  }

  /* ═══════════════════════════════════════
     CHIP — Elevated variant
     ═══════════════════════════════════════ */
  .md-chip__elevation {
    border-radius: inherit;
    inset: 0;
    pointer-events: none;
    position: absolute;
    box-shadow: 0 1px 2px 0 var(--_elevated-container-shadow-color),
                0 1px 3px 1px var(--_elevated-container-shadow-color);
    transition: box-shadow 280ms cubic-bezier(0.2, 0, 0, 1);
  }

  .md-chip--elevated::before {
    background: var(--_elevated-container-color);
  }

  .md-chip--elevated .md-chip__outline {
    border-width: 0;
  }

  .md-chip--elevated:hover .md-chip__elevation {
    box-shadow: 0 1px 2px 0 var(--_elevated-container-shadow-color),
                0 2px 6px 2px var(--_elevated-container-shadow-color);
  }

  .md-chip--elevated:focus-within .md-chip__elevation,
  .md-chip--elevated:active .md-chip__elevation {
    box-shadow: 0 1px 2px 0 var(--_elevated-container-shadow-color),
                0 1px 3px 1px var(--_elevated-container-shadow-color);
  }

  .md-chip--elevated.md-chip--disabled .md-chip__elevation {
    box-shadow: none;
  }

  .md-chip--elevated.md-chip--disabled::before {
    background: var(--_elevated-disabled-container-color);
    opacity: var(--_elevated-disabled-container-opacity);
  }

  /* ═══════════════════════════════════════
     CHIP — Filter selected + elevated
     ═══════════════════════════════════════ */
  .md-chip--filter.md-chip--selected.md-chip--elevated::before {
    background: color-mix(in srgb, var(--color-primary) 20%, var(--surface));
  }

  /* ═══════════════════════════════════════
     CHIP — Disabled checkmark
     ═══════════════════════════════════════ */
  .md-chip--disabled .md-chip__checkmark {
    opacity: var(--_disabled-leading-icon-opacity);
  }

  /* ═══════════════════════════════════════
     High contrast mode
     ═══════════════════════════════════════ */
  @media (forced-colors: active) {
    .md-chip--disabled :is(.md-chip__label, .md-chip__outline, .md-chip__leading-icon) {
      color: GrayText;
      opacity: 1;
    }

    .md-chip--selected:not(.md-chip--elevated)::before {
      border: 1px solid CanvasText;
    }

    .md-chip--selected .md-chip__outline {
      border-width: 1px;
    }

    .md-chip__trailing-icon {
      color: ButtonText;
    }

    .md-chip--disabled .md-chip__trailing-icon {
      color: GrayText;
      opacity: 1;
    }
  }
</style>
