/**
 * Material Design 3 — Select
 * Supports: filled, outlined variants.
 * Custom dropdown with keyboard navigation, click-outside, and floating label.
 *
 * Usage:
 *   <Select label="Fruit" name="fruit">
 *     <SelectOption value="apple" headline="Apple" />
 *     <SelectOption value="banana" headline="Banana" selected />
 *   </Select>
 *
 *   <Select variant="outlined" label="Country" error errorText="Required">
 *     <SelectOption value="us" headline="United States" />
 *   </Select>
 */

interface Props {
  variant?: 'filled' | 'outlined';
  label?: string;
  disabled?: boolean;
  required?: boolean;
  error?: boolean;
  errorText?: string;
  supportingText?: string;
  name?: string;
  class?: string;
  [key: string]: any;
}

const {
  variant = 'filled',
  label,
  disabled = false,
  required = false,
  error = false,
  errorText,
  supportingText,
  name,
  class: className,
  ...attrs
} = Astro.props;

const isFilled = variant === 'filled';
const isOutlined = variant === 'outlined';
const hasError = error && !!errorText;
const helperText = hasError ? errorText : supportingText;
---

<div
  class:list={[
    'md-select',
    `md-select--${variant}`,
    {
      'md-select--disabled': disabled,
      'md-select--error': error,
      'md-select--required': required,
    },
    className,
  ]}
  data-disabled={disabled || undefined}
  {...attrs}
>
  {/* Hidden native select for form submission */}
  <select
    class="md-select__native"
    name={name}
    disabled={disabled}
    required={required}
    aria-hidden="true"
    tabindex="-1"
  >
    <slot />
  </select>

  {/* Custom trigger button */}
  <div
    class="md-select__field"
    role="combobox"
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-controls="md-select-listbox"
    aria-label={label}
    tabindex={disabled ? -1 : 0}
    id="md-select-field"
  >
    {/* Background / outline layer */}
    {isFilled && <span class="md-select__bg" aria-hidden="true"></span>}
    {isOutlined && <span class="md-select__outline" aria-hidden="true"></span>}

    {/* Floating label */}
    {label && (
      <span class="md-select__label" aria-hidden="true">
        {label}{required && <span class="md-select__asterisk"> *</span>}
      </span>
    )}

    {/* Display value */}
    <span class="md-select__display-text" id="md-select-display"></span>

    {/* Trailing icon — animated arrow */}
    <span class="md-select__icon-trailing" aria-hidden="true">
      <svg height="5" viewBox="7 10 10 5" focusable="false" aria-hidden="true">
        <polygon class="md-select__arrow-down" stroke="none" fill-rule="evenodd" points="7 10 12 15 17 10" />
        <polygon class="md-select__arrow-up" stroke="none" fill-rule="evenodd" points="7 15 12 10 17 15" />
      </svg>
    </span>

    {/* Active indicator (filled) */}
    {isFilled && <span class="md-select__active-indicator" aria-hidden="true"></span>}
  </div>

  {/* Dropdown listbox */}
  <div class="md-select__menu-wrapper" aria-hidden="true">
    <ul
      class="md-select__menu"
      role="listbox"
      id="md-select-listbox"
      aria-label={label}
      tabindex="-1"
    >
      <slot />
    </ul>
  </div>

  {/* Supporting / error text */}
  {helperText && (
    <div class:list={['md-select__supporting-text', { 'md-select__supporting-text--error': hasError }]}>
      {helperText}
    </div>
  )}
</div>

<script>
  /**
   * MD Select — vanilla JS controller
   * Handles: open/close, option selection, keyboard nav (arrow, enter, escape),
   * click-outside, floating label, native select sync.
   */
  function initMdSelect(root: HTMLElement) {
    const field = root.querySelector<HTMLElement>('.md-select__field');
    const menu = root.querySelector<HTMLElement>('.md-select__menu');
    const display = root.querySelector<HTMLElement>('.md-select__display-text');
    const nativeSelect = root.querySelector<HTMLSelectElement>('.md-select__native');
    const label = root.querySelector<HTMLElement>('.md-select__label');

    if (!field || !menu || !display) return;

    let isOpen = false;
    let focusedIndex = -1;

    // Build option list from the <ul> — children with role=option
    function getOptions(): HTMLElement[] {
      return Array.from(menu!.querySelectorAll<HTMLElement>('[role="option"]:not([aria-disabled="true"])'));
    }

    // ── Open ────────────────────────────────────────────────────
    function open() {
      if (root.dataset.disabled !== undefined && root.hasAttribute('data-disabled')) return;
      if (isOpen) return;
      isOpen = true;
      root.classList.add('md-select--open');
      field!.setAttribute('aria-expanded', 'true');
      menu!.parentElement!.removeAttribute('aria-hidden');

      // Focus currently selected, or first
      const options = getOptions();
      const selectedEl = options.find(o => o.classList.contains('selected')) ?? options[0];
      if (selectedEl) {
        focusedIndex = options.indexOf(selectedEl);
        highlightOption(options, focusedIndex);
      }
    }

    // ── Close ───────────────────────────────────────────────────
    function close() {
      if (!isOpen) return;
      isOpen = false;
      root.classList.remove('md-select--open');
      field!.setAttribute('aria-expanded', 'false');
      menu!.parentElement!.setAttribute('aria-hidden', 'true');
      focusedIndex = -1;
      clearHighlight();
    }

    // ── Select an option ────────────────────────────────────────
    function selectOption(optionEl: HTMLElement) {
      const allOptions = Array.from(menu!.querySelectorAll<HTMLElement>('[role="option"]'));

      // Deselect all
      allOptions.forEach(o => {
        o.classList.remove('selected');
        o.setAttribute('aria-selected', 'false');
        // Remove existing checkmark
        const check = o.querySelector('.md-select-option__check');
        const leadingIcon = o.querySelector('.md-select-option__leading-icon');
        if (check) check.remove();
        if (leadingIcon) leadingIcon.innerHTML = '';
      });

      // Select this one
      optionEl.classList.add('selected');
      optionEl.setAttribute('aria-selected', 'true');

      // Insert check SVG
      const leadingIcon = optionEl.querySelector('.md-select-option__leading-icon');
      if (leadingIcon) {
        leadingIcon.innerHTML = `<svg class="md-select-option__check" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M9.55 18.2 3.65 12.3 5.275 10.675 9.55 14.95 18.725 5.775 20.35 7.4Z" />
        </svg>`;
      }

      const value = optionEl.getAttribute('data-value') ?? '';
      const headline = optionEl.querySelector('.md-select-option__headline')?.textContent ?? '';

      // Update display
      display!.textContent = headline;

      // Sync native select
      if (nativeSelect) {
        const nativeOption = Array.from(nativeSelect.options).find(o => o.value === value);
        if (nativeOption) nativeSelect.value = value;
      }

      // Float label
      if (label) label.classList.add('md-select__label--floating');
      root.classList.add('md-select--populated');

      // Dispatch change event
      root.dispatchEvent(new Event('change', { bubbles: true }));
      close();
    }

    // ── Highlight / keyboard focus ───────────────────────────────
    function highlightOption(options: HTMLElement[], index: number) {
      clearHighlight();
      if (options[index]) {
        options[index].classList.add('md-select-option--focused');
        options[index].scrollIntoView({ block: 'nearest' });
      }
    }

    function clearHighlight() {
      menu!.querySelectorAll('.md-select-option--focused').forEach(el => {
        el.classList.remove('md-select-option--focused');
      });
    }

    // ── Event listeners ─────────────────────────────────────────
    // Trigger click
    field.addEventListener('click', () => {
      isOpen ? close() : open();
    });

    // Option clicks (delegated)
    menu.addEventListener('click', (e) => {
      const target = (e.target as HTMLElement).closest<HTMLElement>('[role="option"]');
      if (target && !target.getAttribute('aria-disabled')) {
        selectOption(target);
      }
    });

    // Keyboard on trigger
    field.addEventListener('keydown', (e: KeyboardEvent) => {
      const options = getOptions();

      if (!isOpen) {
        if (['Enter', ' ', 'ArrowDown', 'ArrowUp', 'Home', 'End'].includes(e.key)) {
          e.preventDefault();
          open();
          if (e.key === 'End') {
            focusedIndex = options.length - 1;
            highlightOption(options, focusedIndex);
          } else if (e.key === 'Home' || e.key === 'ArrowDown') {
            focusedIndex = 0;
            highlightOption(options, focusedIndex);
          } else if (e.key === 'ArrowUp') {
            focusedIndex = options.length - 1;
            highlightOption(options, focusedIndex);
          }
        }
        return;
      }

      // Menu open — navigate
      switch (e.key) {
        case 'ArrowDown':
          e.preventDefault();
          focusedIndex = Math.min(focusedIndex + 1, options.length - 1);
          highlightOption(options, focusedIndex);
          break;
        case 'ArrowUp':
          e.preventDefault();
          focusedIndex = Math.max(focusedIndex - 1, 0);
          highlightOption(options, focusedIndex);
          break;
        case 'Home':
          e.preventDefault();
          focusedIndex = 0;
          highlightOption(options, focusedIndex);
          break;
        case 'End':
          e.preventDefault();
          focusedIndex = options.length - 1;
          highlightOption(options, focusedIndex);
          break;
        case 'Enter':
        case ' ':
          e.preventDefault();
          if (focusedIndex >= 0 && options[focusedIndex]) {
            selectOption(options[focusedIndex]);
          }
          break;
        case 'Escape':
          e.preventDefault();
          close();
          field.focus();
          break;
        case 'Tab':
          close();
          break;
      }
    });

    // Click outside
    document.addEventListener('click', (e) => {
      if (isOpen && !root.contains(e.target as Node)) {
        close();
      }
    }, { capture: true });

    // Pre-populate display if option is already selected (SSR / server-rendered)
    const preSelected = menu.querySelector<HTMLElement>('[role="option"].selected');
    if (preSelected) {
      const headline = preSelected.querySelector('.md-select-option__headline')?.textContent ?? '';
      display.textContent = headline;
      if (label) label.classList.add('md-select__label--floating');
      root.classList.add('md-select--populated');
    }
  }

  // Init all selects on the page
  document.querySelectorAll<HTMLElement>('.md-select').forEach(initMdSelect);
</script>

<style>
  /* ═══════════════════════════════════════
     SELECT — Root
     ═══════════════════════════════════════ */
  .md-select {
    --_container-height: 56px;
    --_shape: 4px;
    --_shape-rounded: 4px 4px 0 0; /* filled top-rounded */
    --_label-font: var(--font-body);
    --_label-color: var(--text-muted);
    --_label-floating-size: 0.75rem;
    --_label-resting-size: 1rem;
    --_content-color: var(--text);
    --_container-color: color-mix(in srgb, var(--text) 8%, var(--surface));
    --_active-indicator-color: var(--line-strong);
    --_focus-active-indicator-color: var(--color-primary);
    --_focus-label-color: var(--color-primary);
    --_outline-color: var(--line-strong);
    --_focus-outline-color: var(--color-primary);
    --_outline-width: 1px;
    --_focus-outline-width: 3px;
    --_error-color: var(--color-error);
    --_disabled-opacity: 0.38;
    --_supporting-text-color: var(--text-muted);
    --_error-supporting-text-color: var(--color-error);
    --_trailing-icon-color: var(--text-muted);
    --_icon-size: 24px;
    --_menu-bg: var(--surface);
    --_menu-shadow: 0 2px 6px 2px rgba(0,0,0,.15), 0 1px 2px 0 rgba(0,0,0,.3);
    --_menu-shape: 4px;

    position: relative;
    display: inline-flex;
    flex-direction: column;
    min-width: 210px;
    width: 100%;
    font-family: var(--font-body);
  }

  /* ── Disabled state ── */
  .md-select--disabled {
    pointer-events: none;
    cursor: default;
  }

  .md-select--disabled .md-select__field {
    opacity: var(--_disabled-opacity);
  }

  /* ── Native select (hidden, for form submission) ── */
  .md-select__native {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    width: 100%;
    height: 100%;
  }

  /* ═══════════════════════════════════════
     FIELD — Trigger button
     ═══════════════════════════════════════ */
  .md-select__field {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0;
    height: var(--_container-height);
    padding-inline: 16px;
    padding-bottom: 0;
    cursor: pointer;
    outline: none;
    box-sizing: border-box;
    width: 100%;
    color: var(--_content-color);
    font-family: var(--font-body);
    font-size: var(--_label-resting-size);
    line-height: 1.5;
  }

  .md-select__field:focus-visible {
    outline: none; /* handled by active indicator / outline */
  }

  /* ── Background (filled) ── */
  .md-select--filled .md-select__bg {
    position: absolute;
    inset: 0;
    border-radius: 4px 4px 0 0;
    background-color: var(--_container-color);
    transition: background-color 150ms linear;
    pointer-events: none;
  }

  .md-select--filled .md-select__field:hover .md-select__bg {
    background-color: color-mix(in srgb, var(--text) 14%, var(--surface));
  }

  /* ── Active indicator (filled) ── */
  .md-select--filled .md-select__active-indicator {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background-color: var(--_active-indicator-color);
    transform-origin: bottom center;
    transition: height 150ms linear, background-color 150ms linear;
    pointer-events: none;
  }

  .md-select--filled .md-select__field:focus .md-select__active-indicator,
  .md-select--filled.md-select--open .md-select__active-indicator {
    height: 2px;
    background-color: var(--_focus-active-indicator-color);
  }

  .md-select--filled.md-select--error .md-select__active-indicator {
    background-color: var(--_error-color);
  }

  /* ── Outline (outlined) ── */
  .md-select--outlined .md-select__field {
    padding-top: 0;
  }

  .md-select--outlined .md-select__outline {
    position: absolute;
    inset: 0;
    border: var(--_outline-width) solid var(--_outline-color);
    border-radius: var(--_shape);
    pointer-events: none;
    transition: border-color 150ms linear, border-width 150ms linear;
    box-sizing: border-box;
  }

  .md-select--outlined .md-select__field:focus .md-select__outline,
  .md-select--outlined.md-select--open .md-select__outline {
    border-color: var(--_focus-outline-color);
    border-width: var(--_focus-outline-width);
  }

  .md-select--outlined.md-select--error .md-select__outline {
    border-color: var(--_error-color);
  }

  /* ═══════════════════════════════════════
     LABEL — Floating
     ═══════════════════════════════════════ */
  .md-select__label {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--_label-font);
    font-size: var(--_label-resting-size);
    line-height: 1.5;
    color: var(--_label-color);
    pointer-events: none;
    transition: top 150ms cubic-bezier(0.2, 0, 0, 1),
                font-size 150ms cubic-bezier(0.2, 0, 0, 1),
                color 150ms cubic-bezier(0.2, 0, 0, 1),
                transform 150ms cubic-bezier(0.2, 0, 0, 1);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: calc(100% - 48px);
    z-index: 1;
  }

  /* Filled: floating label goes to top */
  .md-select--filled .md-select__label--floating,
  .md-select--filled.md-select--populated .md-select__label,
  .md-select--filled.md-select--open .md-select__label {
    top: 10px;
    transform: translateY(0);
    font-size: var(--_label-floating-size);
    color: var(--_label-color);
  }

  .md-select--filled .md-select__field:focus ~ .md-select__label,
  .md-select--filled.md-select--open .md-select__label {
    color: var(--_focus-label-color);
  }

  /* Outlined: label floats above border */
  .md-select--outlined .md-select__label {
    left: 12px;
    padding-inline: 4px;
    background-color: var(--surface);
  }

  .md-select--outlined .md-select__label--floating,
  .md-select--outlined.md-select--populated .md-select__label,
  .md-select--outlined.md-select--open .md-select__label {
    top: 0;
    transform: translateY(-50%);
    font-size: var(--_label-floating-size);
  }

  .md-select--outlined.md-select--open .md-select__label {
    color: var(--_focus-outline-color);
  }

  /* Error label */
  .md-select--error .md-select__label {
    color: var(--_error-color);
  }

  /* Asterisk */
  .md-select__asterisk {
    color: var(--_error-color);
  }

  /* ═══════════════════════════════════════
     DISPLAY TEXT
     ═══════════════════════════════════════ */
  .md-select__display-text {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    /* Push below floating label for filled */
    padding-top: 0;
    position: relative;
    z-index: 0;
  }

  .md-select--filled.md-select--populated .md-select__display-text,
  .md-select--filled.md-select--open .md-select__display-text {
    padding-top: 18px;
    /* When label is floating, shift content down so it fills the lower half */
  }

  /* ═══════════════════════════════════════
     TRAILING ICON — Animated arrow
     ═══════════════════════════════════════ */
  .md-select__icon-trailing {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--_icon-size);
    height: var(--_icon-size);
    flex-shrink: 0;
    margin-inline-start: 4px;
    color: var(--_trailing-icon-color);
    fill: currentColor;
    transition: transform 200ms cubic-bezier(0.2, 0, 0, 1);
    position: relative;
    z-index: 1;
  }

  .md-select__icon-trailing svg {
    fill: currentColor;
    overflow: visible;
  }

  /* Animate arrow chevron */
  .md-select__arrow-down,
  .md-select__arrow-up {
    opacity: 0;
    transition: opacity 75ms linear 75ms;
    fill: currentColor;
  }

  .md-select:not(.md-select--open) .md-select__arrow-down,
  .md-select--open .md-select__arrow-up {
    opacity: 1;
  }

  /* ═══════════════════════════════════════
     MENU WRAPPER + LISTBOX
     ═══════════════════════════════════════ */
  .md-select__menu-wrapper {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 1000;
    pointer-events: none;
    height: 0;
    overflow: visible;
  }

  .md-select__menu {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    background-color: var(--_menu-bg);
    border-radius: var(--_menu-shape);
    box-shadow: var(--_menu-shadow);
    list-style: none;
    margin: 0;
    padding: 8px 0;
    max-height: 280px;
    overflow-y: auto;
    overflow-x: hidden;
    overscroll-behavior: contain;
    pointer-events: none;
    transform: scaleY(0.8);
    transform-origin: top center;
    opacity: 0;
    transition:
      opacity 120ms cubic-bezier(0.2, 0, 0, 1),
      transform 120ms cubic-bezier(0.2, 0, 0, 1);
    box-sizing: border-box;
  }

  /* Open state */
  .md-select--open .md-select__menu-wrapper {
    pointer-events: auto;
  }

  .md-select--open .md-select__menu {
    opacity: 1;
    transform: scaleY(1);
    pointer-events: auto;
  }

  /* ── Focused option highlight (keyboard) ── */
  :global(.md-select-option--focused) {
    background-color: color-mix(in srgb, var(--text) 12%, var(--surface)) !important;
    outline: none;
  }

  /* ═══════════════════════════════════════
     SUPPORTING TEXT
     ═══════════════════════════════════════ */
  .md-select__supporting-text {
    font-family: var(--font-body);
    font-size: 0.75rem;
    line-height: 1.333;
    color: var(--_supporting-text-color);
    padding-inline: 16px;
    padding-top: 4px;
  }

  .md-select__supporting-text--error {
    color: var(--_error-supporting-text-color);
  }

  /* ═══════════════════════════════════════
     HIGH CONTRAST MODE
     ═══════════════════════════════════════ */
  @media (forced-colors: active) {
    .md-select__outline,
    .md-select__active-indicator {
      border-color: ButtonText;
      background-color: ButtonText;
    }

    .md-select--disabled .md-select__field {
      color: GrayText;
      opacity: 1;
    }

    .md-select--disabled .md-select__outline,
    .md-select--disabled .md-select__active-indicator {
      border-color: GrayText;
      background-color: GrayText;
    }
  }
</style>
