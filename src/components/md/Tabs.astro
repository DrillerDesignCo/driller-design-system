/**
 * Material Design 3 — Tabs
 * Scrollable tab bar container.
 *
 * Usage:
 *   <Tabs>
 *     <Tab label="Tab 1" active />
 *     <Tab label="Tab 2" />
 *   </Tabs>
 *
 * Props:
 *   activeTab  – zero-based index of the initially active tab (default: 0)
 *   class      – additional classes forwarded to the host element
 */

interface Props {
  activeTab?: number;
  class?: string;
  [key: string]: any;
}

const {
  activeTab = 0,
  class: className,
  ...attrs
} = Astro.props;
---

<div
  class:list={['md-tabs', className]}
  role="tablist"
  data-active-tab={activeTab}
  {...attrs}
>
  <div class="md-tabs__scroller">
    <slot />
  </div>
  <div class="md-tabs__divider" aria-hidden="true"></div>
</div>

<script>
  /**
   * Tabs — vanilla JS controller
   * Handles: click selection, keyboard nav (← → Home End), indicator animation.
   */
  function initTabs(tabsEl: HTMLElement) {
    const EASING = 'cubic-bezier(0.2, 0, 0, 1)';

    function getTabs(): HTMLElement[] {
      return Array.from(tabsEl.querySelectorAll<HTMLElement>('.md-tab'));
    }

    function getIndicator(tab: HTMLElement): HTMLElement | null {
      return tab.querySelector<HTMLElement>('.md-tab__indicator');
    }

    /** Activates a tab, animates the indicator from the previously active one. */
    function activateTab(nextTab: HTMLElement) {
      const tabs = getTabs();
      const prevTab = tabs.find((t) => t.classList.contains('md-tab--active'));

      if (prevTab === nextTab) return;

      // Capture prev indicator rect BEFORE state change.
      const prevIndicator = prevTab ? getIndicator(prevTab) : null;
      const prevRect = prevIndicator?.getBoundingClientRect() ?? null;

      // Update active state.
      tabs.forEach((t) => {
        const isNext = t === nextTab;
        t.classList.toggle('md-tab--active', isNext);
        t.setAttribute('aria-selected', String(isNext));
        t.setAttribute('tabindex', isNext ? '0' : '-1');
      });

      // Animate indicator on the newly active tab.
      const nextIndicator = getIndicator(nextTab);
      if (nextIndicator && prevRect) {
        const toRect = nextIndicator.getBoundingClientRect();
        if (toRect.width > 0) {
          const scale = prevRect.width / toRect.width;
          const translateX = prevRect.left - toRect.left;
          const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

          if (!reduceMotion && isFinite(scale) && isFinite(translateX)) {
            nextIndicator.animate(
              [
                { transform: `translateX(${translateX.toFixed(4)}px) scaleX(${scale.toFixed(4)})` },
                { transform: 'none' },
              ],
              { duration: 250, easing: EASING }
            );
          }
        }
      }

      // Scroll active tab into view.
      scrollToTab(nextTab);

      tabsEl.dispatchEvent(new Event('change', { bubbles: true }));
    }

    function scrollToTab(tab: HTMLElement) {
      const scroller = tabsEl.querySelector<HTMLElement>('.md-tabs__scroller');
      if (!scroller) return;
      const offset = tab.offsetLeft;
      const extent = tab.offsetWidth;
      const scroll = scroller.scrollLeft;
      const hostExtent = scroller.offsetWidth;
      const margin = 48;
      const min = offset - margin;
      const max = offset + extent - hostExtent + margin;
      const to = Math.min(min, Math.max(max, scroll));
      scroller.scrollTo({ behavior: 'smooth', top: 0, left: to });
    }

    // --- initialise first active tab ---
    const tabs = getTabs();
    const firstActive = tabs.find((t) => t.classList.contains('md-tab--active'));
    if (!firstActive && tabs[0]) {
      tabs[0].classList.add('md-tab--active');
      tabs[0].setAttribute('aria-selected', 'true');
      tabs[0].setAttribute('tabindex', '0');
    }
    tabs.forEach((t) => {
      if (!t.hasAttribute('aria-selected')) t.setAttribute('aria-selected', 'false');
      if (!t.hasAttribute('tabindex')) t.setAttribute('tabindex', '-1');
    });

    // --- click ---
    tabsEl.addEventListener('click', (e: Event) => {
      const tab = (e.target as HTMLElement).closest<HTMLElement>('.md-tab');
      if (tab && tabsEl.contains(tab)) activateTab(tab);
    });

    // --- keyboard ---
    tabsEl.addEventListener('keydown', (e: KeyboardEvent) => {
      const tabs = getTabs();
      if (tabs.length < 2) return;

      const isLeft = e.key === 'ArrowLeft';
      const isRight = e.key === 'ArrowRight';
      const isHome = e.key === 'Home';
      const isEnd = e.key === 'End';
      const isEnter = e.key === 'Enter' || e.key === ' ';

      if (!isLeft && !isRight && !isHome && !isEnd && !isEnter) return;
      e.preventDefault();

      const focusedTab = tabs.find((t) => t === document.activeElement || t.contains(document.activeElement));
      const focusedIndex = focusedTab ? tabs.indexOf(focusedTab) : -1;

      if (isEnter && focusedTab) {
        activateTab(focusedTab);
        return;
      }

      const isRtl = getComputedStyle(tabsEl).direction === 'rtl';
      let nextIndex: number;

      if (isHome) {
        nextIndex = 0;
      } else if (isEnd) {
        nextIndex = tabs.length - 1;
      } else {
        const forwards = isRtl ? isLeft : isRight;
        if (focusedIndex === -1) {
          nextIndex = forwards ? 0 : tabs.length - 1;
        } else {
          nextIndex = focusedIndex + (forwards ? 1 : -1);
          if (nextIndex >= tabs.length) nextIndex = 0;
          if (nextIndex < 0) nextIndex = tabs.length - 1;
        }
      }

      tabs[nextIndex].focus();
      scrollToTab(tabs[nextIndex]);
    });

    // Restore focus to active tab on blur-out.
    tabsEl.addEventListener('focusout', () => {
      if (tabsEl.matches(':focus-within')) return;
      const active = getTabs().find((t) => t.classList.contains('md-tab--active'));
      if (active) active.setAttribute('tabindex', '0');
    });
  }

  document.querySelectorAll<HTMLElement>('.md-tabs').forEach(initTabs);
</script>

<style>
  /* ═══════════════════════════════════════
     TABS — Container
     ═══════════════════════════════════════ */
  .md-tabs {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    position: relative;
    width: 100%;
  }

  .md-tabs__scroller {
    align-items: flex-end;
    display: flex;
    height: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    scrollbar-width: none;
    width: 100%;
  }

  .md-tabs__scroller::-webkit-scrollbar {
    display: none;
  }

  /* Each slotted tab stretches equally */
  .md-tabs__scroller :global(.md-tab) {
    flex: 1;
  }

  /* Active tab renders on top so its indicator slides over neighbours */
  .md-tabs__scroller :global(.md-tab--active) {
    z-index: 1;
  }

  /* Divider */
  .md-tabs__divider {
    background: var(--line);
    height: 1px;
    width: 100%;
    flex-shrink: 0;
  }
</style>
