---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  headline?: string;
  /** Set to true to inject FAQPage JSON-LD schema */
  jsonLd?: boolean;
}

const { items, headline = "Frequently Asked Questions", jsonLd = true } = Astro.props;

// Build FAQPage structured data
const faqSchema = jsonLd ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
}) : null;
---

{jsonLd && faqSchema && (
  <script type="application/ld+json" set:html={faqSchema} />
)}

<section class="py-24 bg-surface" id="faq">
  <div class="max-w-7xl mx-auto px-6 md:px-12 flex flex-col md:flex-row gap-16">
    <div class="md:w-1/3">
      <h2 class="text-4xl md:text-5xl font-bold text-dark leading-tight sticky top-32">{headline}</h2>
    </div>
    <div class="md:w-2/3 flex flex-col gap-6">
      {items.map((item) => (
        <details class="group bg-surface-container-highest rounded-2xl overflow-hidden hover:bg-surface-container-low transition-colors shadow-[0_4px_6px_-1px_rgba(0,0,0,0.05)] [&_summary::-webkit-details-marker]:hidden">
          <summary class="flex justify-between items-center p-8 cursor-pointer list-none text-lg font-bold text-dark transition-colors">
            <span>{item.question}</span>
            <svg class="text-primary transition-transform duration-300 group-open:rotate-180 flex-shrink-0" width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </summary>
          <div class="px-8 pb-8 text-on-surface-variant leading-relaxed">
            <p>{item.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
