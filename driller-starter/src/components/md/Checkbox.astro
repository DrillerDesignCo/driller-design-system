---
/**
 * Material Design 3 — Checkbox
 * Supports: checked, indeterminate, disabled states
 *
 * Usage:
 *   <Checkbox />
 *   <Checkbox checked />
 *   <Checkbox indeterminate />
 *   <Checkbox disabled />
 *   <Checkbox name="agree" value="yes" required />
 */

interface Props {
  checked?: boolean;
  indeterminate?: boolean;
  disabled?: boolean;
  required?: boolean;
  name?: string;
  value?: string;
  class?: string;
  [key: string]: any;
}

const {
  checked = false,
  indeterminate = false,
  disabled = false,
  required = false,
  name,
  value = 'on',
  class: className,
  ...attrs
} = Astro.props;

const isChecked = checked && !indeterminate;
const isIndeterminate = indeterminate;
const isSelected = isChecked || isIndeterminate;
---

<label
  class:list={[
    'md-checkbox',
    {
      'md-checkbox--selected': isSelected,
      'md-checkbox--unselected': !isSelected,
      'md-checkbox--checked': isChecked,
      'md-checkbox--indeterminate': isIndeterminate,
      'md-checkbox--disabled': disabled,
    },
    className,
  ]}
  {...attrs}
>
  <input
    type="checkbox"
    class="md-checkbox__input"
    checked={checked}
    disabled={disabled}
    required={required}
    name={name}
    value={value}
    aria-checked={isIndeterminate ? 'mixed' : undefined}
  />

  <div class="md-checkbox__container">
    <div class="md-checkbox__outline"></div>
    <div class="md-checkbox__background"></div>
    <svg class="md-checkbox__icon" viewBox="0 0 18 18" aria-hidden="true">
      <rect class="md-checkbox__mark md-checkbox__mark--short" />
      <rect class="md-checkbox__mark md-checkbox__mark--long" />
    </svg>
  </div>
</label>

<script>
  document.querySelectorAll('.md-checkbox').forEach((el) => {
    const input = el.querySelector('input') as HTMLInputElement | null;
    if (!input) return;

    // Set initial indeterminate state (HTML attribute can't set this)
    if (el.classList.contains('md-checkbox--indeterminate')) {
      input.indeterminate = true;
    }

    input.addEventListener('change', () => {
      const isNowChecked = input.checked;
      const isNowIndeterminate = input.indeterminate;
      const selected = isNowChecked || isNowIndeterminate;

      // Update container classes
      el.classList.toggle('md-checkbox--selected', selected);
      el.classList.toggle('md-checkbox--unselected', !selected);
      el.classList.toggle('md-checkbox--checked', isNowChecked && !isNowIndeterminate);
      el.classList.toggle('md-checkbox--indeterminate', isNowIndeterminate);
    });
  });
</script>

<style>
  /* ═══════════════════════════════════════
     CHECKBOX — Root
     ═══════════════════════════════════════ */
  .md-checkbox {
    --_container-shape: var(--md-checkbox-container-shape, 2px);
    --_container-size: var(--md-checkbox-container-size, 18px);
    --_icon-size: var(--md-checkbox-icon-size, 18px);
    --_outline-color: var(--md-checkbox-outline-color, var(--text-muted));
    --_outline-width: var(--md-checkbox-outline-width, 2px);
    --_selected-container-color: var(--md-checkbox-selected-container-color, var(--color-primary));
    --_selected-icon-color: var(--md-checkbox-selected-icon-color, var(--color-dark));
    --_state-layer-size: var(--md-checkbox-state-layer-size, 40px);
    --_disabled-outline-color: var(--md-checkbox-disabled-outline-color, var(--text));
    --_disabled-container-opacity: var(--md-checkbox-disabled-container-opacity, 0.38);
    --_selected-disabled-container-color: var(--md-checkbox-selected-disabled-container-color, var(--text));
    --_selected-disabled-container-opacity: var(--md-checkbox-selected-disabled-container-opacity, 0.38);
    --_selected-disabled-icon-color: var(--md-checkbox-selected-disabled-icon-color, var(--surface));

    border-radius: var(--_container-shape);
    display: inline-flex;
    height: var(--_state-layer-size);
    width: var(--_state-layer-size);
    position: relative;
    vertical-align: top;
    cursor: pointer;
    place-content: center;
    place-items: center;
    -webkit-tap-highlight-color: transparent;
  }

  .md-checkbox--disabled {
    cursor: default;
    pointer-events: none;
  }

  /* ═══════════════════════════════════════
     CHECKBOX — Hidden native input (touch target)
     ═══════════════════════════════════════ */
  .md-checkbox__input {
    appearance: none;
    height: 48px;
    width: 48px;
    margin: 0;
    opacity: 0;
    outline: none;
    position: absolute;
    z-index: 1;
    cursor: inherit;
  }

  /* ═══════════════════════════════════════
     CHECKBOX — Container
     ═══════════════════════════════════════ */
  .md-checkbox__container {
    border-radius: var(--_container-shape);
    display: flex;
    height: var(--_container-size);
    width: var(--_container-size);
    place-content: center;
    place-items: center;
    position: relative;
  }

  /* ═══════════════════════════════════════
     CHECKBOX — Outline & background
     ═══════════════════════════════════════ */
  .md-checkbox__outline,
  .md-checkbox__background,
  .md-checkbox__icon {
    inset: 0;
    position: absolute;
  }

  .md-checkbox__outline,
  .md-checkbox__background {
    border-radius: inherit;
  }

  .md-checkbox__outline {
    border-color: var(--_outline-color);
    border-style: solid;
    border-width: var(--_outline-width);
    box-sizing: border-box;
  }

  .md-checkbox__background {
    background-color: var(--_selected-container-color);
  }

  /* Background and icon — hidden by default, shown when selected */
  .md-checkbox__background,
  .md-checkbox__icon {
    opacity: 0;
    transition-duration: 150ms, 50ms;
    transition-property: transform, opacity;
    transition-timing-function: cubic-bezier(0.3, 0, 0.8, 0.15), linear;
    transform: scale(0.6);
  }

  .md-checkbox--selected .md-checkbox__background,
  .md-checkbox--selected .md-checkbox__icon {
    opacity: 1;
    transition-duration: 350ms, 50ms;
    transition-timing-function: cubic-bezier(0.05, 0.7, 0.1, 1), linear;
    transform: scale(1);
  }

  /* ═══════════════════════════════════════
     CHECKBOX — Icon (SVG checkmark / indeterminate)
     ═══════════════════════════════════════ */
  .md-checkbox__icon {
    fill: var(--_selected-icon-color);
    height: var(--_icon-size);
    width: var(--_icon-size);
  }

  /* Mark base styles */
  .md-checkbox__mark {
    animation-duration: 150ms;
    animation-timing-function: cubic-bezier(0.3, 0, 0.8, 0.15);
    transition-duration: 150ms;
    transition-timing-function: cubic-bezier(0.3, 0, 0.8, 0.15);
  }

  .md-checkbox__mark--short {
    height: 2px;
    width: 2px;
    transition-property: transform, height;
  }

  .md-checkbox__mark--long {
    height: 2px;
    width: 10px;
    transition-property: transform, width;
  }

  /* Enter duration and easing for selected state */
  .md-checkbox--selected .md-checkbox__mark {
    animation-duration: 350ms;
    animation-timing-function: cubic-bezier(0.05, 0.7, 0.1, 1);
    transition-duration: 350ms;
    transition-timing-function: cubic-bezier(0.05, 0.7, 0.1, 1);
  }

  /* ═══════════════════════════════════════
     CHECKBOX — Checkmark icon shape
     ═══════════════════════════════════════ */
  .md-checkbox--checked .md-checkbox__mark {
    /* scaleY(-1) fixes Safari transform-origin; translate positions the bottom-left
       corner at the checkmark point; rotate(45deg) forms the checkmark angle */
    transform: scaleY(-1) translate(7px, -14px) rotate(45deg);
  }

  .md-checkbox--checked .md-checkbox__mark--short {
    /* √(4² + 4²) ≈ 5.66px — the short arm of the checkmark */
    height: 5.66px;
  }

  .md-checkbox--checked .md-checkbox__mark--long {
    /* √(8² + 8²) ≈ 11.31px — the long arm of the checkmark */
    width: 11.31px;
  }

  /* Checkmark entry animation from unchecked */
  .md-checkbox--checked .md-checkbox__mark--long {
    animation-name: md-checkbox-prev-unselected-to-checked;
  }

  @keyframes md-checkbox-prev-unselected-to-checked {
    from {
      width: 0;
    }
  }

  /* ═══════════════════════════════════════
     CHECKBOX — Indeterminate icon shape
     ═══════════════════════════════════════ */
  .md-checkbox--indeterminate .md-checkbox__mark {
    transform: scaleY(-1) translate(4px, -10px) rotate(0deg);
  }

  /* ═══════════════════════════════════════
     CHECKBOX — Hover states
     ═══════════════════════════════════════ */
  .md-checkbox:hover .md-checkbox__outline {
    border-color: var(--md-checkbox-hover-outline-color, var(--text));
  }

  .md-checkbox:hover.md-checkbox--selected .md-checkbox__background {
    background-color: var(--md-checkbox-selected-hover-container-color, var(--color-primary));
  }

  .md-checkbox:hover.md-checkbox--selected .md-checkbox__icon {
    fill: var(--md-checkbox-selected-hover-icon-color, var(--color-dark));
  }

  /* ═══════════════════════════════════════
     CHECKBOX — Focus states
     ═══════════════════════════════════════ */
  .md-checkbox:focus-within .md-checkbox__outline {
    border-color: var(--md-checkbox-focus-outline-color, var(--text));
  }

  .md-checkbox:focus-within.md-checkbox--selected .md-checkbox__background {
    background-color: var(--md-checkbox-selected-focus-container-color, var(--color-primary));
  }

  .md-checkbox:focus-within.md-checkbox--selected .md-checkbox__icon {
    fill: var(--md-checkbox-selected-focus-icon-color, var(--color-dark));
  }

  .md-checkbox__input:focus-visible ~ .md-checkbox__container {
    outline: 3px solid var(--md-focus-ring-color, var(--focus-ring));
    outline-offset: 2px;
    border-radius: var(--_container-shape);
  }

  /* ═══════════════════════════════════════
     CHECKBOX — Active/pressed states
     ═══════════════════════════════════════ */
  .md-checkbox:active .md-checkbox__outline {
    border-color: var(--md-checkbox-pressed-outline-color, var(--text));
  }

  .md-checkbox:active.md-checkbox--selected .md-checkbox__background {
    background-color: var(--md-checkbox-selected-pressed-container-color, var(--color-primary));
  }

  .md-checkbox:active.md-checkbox--selected .md-checkbox__icon {
    fill: var(--md-checkbox-selected-pressed-icon-color, var(--color-dark));
  }

  /* ═══════════════════════════════════════
     CHECKBOX — Disabled states
     ═══════════════════════════════════════ */
  .md-checkbox--disabled .md-checkbox__background,
  .md-checkbox--disabled .md-checkbox__icon,
  .md-checkbox--disabled .md-checkbox__mark {
    animation-duration: 0s;
    transition-duration: 0s;
  }

  .md-checkbox--disabled .md-checkbox__outline {
    border-color: var(--_disabled-outline-color);
    opacity: var(--_disabled-container-opacity);
  }

  .md-checkbox--disabled.md-checkbox--selected .md-checkbox__outline {
    visibility: hidden;
  }

  .md-checkbox--disabled.md-checkbox--selected .md-checkbox__background {
    background-color: var(--_selected-disabled-container-color);
    opacity: var(--_selected-disabled-container-opacity);
  }

  .md-checkbox--disabled .md-checkbox__icon {
    fill: var(--_selected-disabled-icon-color);
  }

  /* ═══════════════════════════════════════
     CHECKBOX — Forced colors (high contrast)
     ═══════════════════════════════════════ */
  @media (forced-colors: active) {
    .md-checkbox__background {
      background-color: CanvasText;
    }

    .md-checkbox--selected.md-checkbox--disabled .md-checkbox__background {
      background-color: GrayText;
      opacity: 1;
    }

    .md-checkbox__outline {
      border-color: CanvasText;
    }

    .md-checkbox--disabled .md-checkbox__outline {
      border-color: GrayText;
      opacity: 1;
    }

    .md-checkbox__icon {
      fill: Canvas;
    }
  }
</style>
