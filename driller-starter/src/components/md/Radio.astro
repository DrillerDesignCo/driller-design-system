---
/**
 * Material Design 3 — Radio
 * A radio button that allows users to select one option from a set.
 *
 * Usage:
 *   <Radio name="color" value="red" />
 *   <Radio name="color" value="blue" checked />
 *   <Radio name="color" value="green" disabled />
 */

interface Props {
  checked?: boolean;
  disabled?: boolean;
  required?: boolean;
  name?: string;
  value?: string;
  class?: string;
  [key: string]: any;
}

const {
  checked = false,
  disabled = false,
  required = false,
  name,
  value = 'on',
  class: className,
  ...attrs
} = Astro.props;
---

<label
  class:list={[
    'md-radio',
    {
      'md-radio--checked': checked,
      'md-radio--disabled': disabled,
    },
    className,
  ]}
  {...attrs}
>
  <input
    type="radio"
    class="md-radio__input"
    checked={checked}
    disabled={disabled}
    required={required}
    name={name}
    value={value}
  />

  {/* Visual container */}
  <div class="md-radio__container" aria-hidden="true">
    {/* Ripple */}
    <span class="md-ripple"></span>

    {/* SVG icon: outer ring (masked) + inner dot */}
    <svg class="md-radio__icon" viewBox="0 0 20 20">
      <mask id="radioMask">
        <rect width="100%" height="100%" fill="white" />
        <circle cx="10" cy="10" r="8" fill="black" />
      </mask>
      <circle
        class="md-radio__outer-circle"
        cx="10"
        cy="10"
        r="10"
        mask="url(#radioMask)"
      />
      <circle class="md-radio__inner-circle" cx="10" cy="10" r="5" />
    </svg>

    {/* Touch target */}
    <div class="md-radio__touch"></div>
  </div>
</label>

<script>
  // Assign unique mask IDs to avoid Safari bug with shared mask references
  let maskCounter = 0;
  document.querySelectorAll('.md-radio').forEach((el) => {
    const input = el.querySelector('input[type="radio"]') as HTMLInputElement | null;
    const svg = el.querySelector('.md-radio__icon');
    const mask = svg?.querySelector('mask');
    const outerCircle = svg?.querySelector('.md-radio__outer-circle');

    // Assign unique mask id
    if (mask && outerCircle) {
      const uid = `radioMask${++maskCounter}`;
      mask.id = uid;
      outerCircle.setAttribute('mask', `url(#${uid})`);
    }

    if (!input) return;

    // Sync checked state visually
    const sync = () => {
      // When a radio in a group is selected, all others in the group uncheck.
      // We need to update all radios in the same name group.
      const groupName = input.name;
      if (groupName) {
        document.querySelectorAll<HTMLElement>(`.md-radio`).forEach((radio) => {
          const ri = radio.querySelector('input[type="radio"]') as HTMLInputElement | null;
          if (ri && ri.name === groupName) {
            radio.classList.toggle('md-radio--checked', ri.checked);
          }
        });
      } else {
        el.classList.toggle('md-radio--checked', input.checked);
      }
    };

    input.addEventListener('change', sync);
  });
</script>

<style>
  /* ═══════════════════════════════════════
     RADIO — Root
     ═══════════════════════════════════════ */
  .md-radio {
    display: inline-flex;
    height: 20px;
    width: 20px;
    outline: none;
    position: relative;
    vertical-align: top;
    -webkit-tap-highlight-color: transparent;
    cursor: pointer;
  }

  .md-radio--disabled {
    cursor: default;
    pointer-events: none;
  }

  /* ═══════════════════════════════════════
     Hidden native input
     ═══════════════════════════════════════ */
  .md-radio__input {
    appearance: none;
    position: absolute;
    inset: 0;
    margin: 0;
    padding: 0;
    opacity: 0;
    cursor: inherit;
    z-index: 1;
  }

  /* ═══════════════════════════════════════
     Visual container
     ═══════════════════════════════════════ */
  .md-radio__container {
    display: flex;
    height: 100%;
    width: 100%;
    place-content: center;
    place-items: center;
  }

  /* ═══════════════════════════════════════
     Focus ring
     ═══════════════════════════════════════ */
  .md-radio__input:focus-visible ~ .md-radio__container {
    outline: 3px solid var(--md-focus-ring-color, var(--focus-ring));
    outline-offset: 2px;
    border-radius: 50%;
  }

  /* ═══════════════════════════════════════
     Touch target
     ═══════════════════════════════════════ */
  .md-radio__touch {
    height: 48px;
    width: 48px;
    position: absolute;
  }

  /* ═══════════════════════════════════════
     Ripple
     ═══════════════════════════════════════ */
  .md-radio > .md-ripple {
    border-radius: 50%;
    height: 40px;
    width: 40px;
    inset: unset;
    position: absolute;
  }

  /* ═══════════════════════════════════════
     SVG icon
     ═══════════════════════════════════════ */
  .md-radio__icon {
    fill: var(--line-strong);
    inset: 0;
    position: absolute;
  }

  /* ── Outer ring ── */
  .md-radio__outer-circle {
    transition: fill 50ms linear;
  }

  /* ── Inner dot ── */
  .md-radio__inner-circle {
    opacity: 0;
    transform-origin: center;
    transition: opacity 50ms linear;
  }

  /* ═══════════════════════════════════════
     CHECKED state
     ═══════════════════════════════════════ */
  .md-radio--checked .md-radio__icon {
    fill: var(--color-primary);
  }

  .md-radio--checked .md-radio__inner-circle {
    animation: md-radio-inner-circle-grow 300ms cubic-bezier(0.05, 0.7, 0.1, 1);
    opacity: 1;
  }

  @keyframes md-radio-inner-circle-grow {
    from {
      transform: scale(0);
    }
    to {
      transform: scale(1);
    }
  }

  /* ═══════════════════════════════════════
     Hover states
     ═══════════════════════════════════════ */
  .md-radio:hover .md-radio__icon {
    fill: var(--text);
  }

  .md-radio:hover.md-radio--checked .md-radio__icon {
    fill: var(--color-primary);
  }

  /* ═══════════════════════════════════════
     Focus states
     ═══════════════════════════════════════ */
  .md-radio:focus-within .md-radio__icon {
    fill: var(--text);
  }

  .md-radio:focus-within.md-radio--checked .md-radio__icon {
    fill: var(--color-primary);
  }

  /* ═══════════════════════════════════════
     Active/pressed states
     ═══════════════════════════════════════ */
  .md-radio:active .md-radio__icon {
    fill: var(--text);
  }

  .md-radio:active.md-radio--checked .md-radio__icon {
    fill: var(--color-primary);
  }

  /* ═══════════════════════════════════════
     DISABLED state
     ═══════════════════════════════════════ */
  .md-radio--disabled .md-radio__icon {
    fill: var(--text);
    opacity: 0.38;
  }

  .md-radio--disabled.md-radio--checked .md-radio__icon {
    fill: var(--text);
    opacity: 0.38;
  }

  .md-radio--disabled .md-radio__outer-circle,
  .md-radio--disabled .md-radio__inner-circle {
    animation-duration: 0s;
    transition-duration: 0s;
  }

  /* ═══════════════════════════════════════
     Forced colors (high contrast mode)
     ═══════════════════════════════════════ */
  @media (forced-colors: active) {
    .md-radio__icon {
      fill: CanvasText;
    }

    .md-radio--disabled .md-radio__icon {
      fill: GrayText;
      opacity: 1;
    }
  }
</style>
